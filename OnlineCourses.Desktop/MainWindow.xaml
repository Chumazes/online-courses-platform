<Window x:Class="OnlineCourses.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Online Courses Platform"
        Width="1100"
        Height="700"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#F3F4F6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="16"
                Background="#111827">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="Online Courses" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="BackButton"
                            Width="90"
                            Margin="0,0,8,0"
                            Click="BackButton_OnClick"
                            Content="Назад"
                            Visibility="Collapsed" />
                    <Button x:Name="ProfileBadge"
                            Margin="0,0,8,0"
                            Padding="0"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Click="ProfileBadge_OnClick"
                            Cursor="Hand"
                            Visibility="Collapsed">
                        <Border Padding="12,6"
                                Background="#1F2937"
                                BorderBrush="#374151"
                                BorderThickness="1"
                                CornerRadius="12">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="34"
                                        Height="34"
                                        Margin="0,0,10,0"
                                        Background="#2563EB"
                                        CornerRadius="17">
                                    <TextBlock x:Name="UserInitialsText"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Foreground="White"
                                               Text="?" />
                                </Border>

                                <StackPanel>
                                    <TextBlock x:Name="UserNameText"
                                               FontWeight="SemiBold"
                                               Foreground="White"
                                               Text="Профиль" />
                                    <TextBlock x:Name="UserRoleText"
                                               FontSize="12"
                                               Foreground="#9CA3AF"
                                               Text="Не загружен" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Button>
                    <Button x:Name="LogoutButton"
                            Width="120"
                            Click="LogoutButton_OnClick"
                            Content="Выйти"
                            Visibility="Collapsed" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Frame x:Name="MainFrame"
               Grid.Row="1"
               NavigationUIVisibility="Hidden" />
    </Grid>
</Window>
