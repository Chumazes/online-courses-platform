<Page x:Class="OnlineCourses.Desktop.Pages.ManageCategoriesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="ManageCategoriesPage">
    <Grid Margin="26">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.05*" />
            <ColumnDefinition Width="1.15*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0"
              Margin="0,0,18,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="22"
                    Background="#7A43AE"
                    BorderBrush="#A97AD4"
                    BorderThickness="1"
                    CornerRadius="28">
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock FontSize="30"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource LltLightTextBrush}"
                                   Text="Категории платформы" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="#E7D8F7"
                                   Text="Администратор управляет структурами каталога и фильтрами витрины." />
                    </StackPanel>

                    <Button DockPanel.Dock="Right"
                            Width="170"
                            Style="{StaticResource LltLightButtonStyle}"
                            Click="CreateCategoryButton_OnClick"
                            Content="Новая категория" />
                </DockPanel>
            </Border>

            <TextBlock Grid.Row="1"
                       Margin="6,12,0,0"
                       Foreground="#9A1C30"
                       Text="{Binding ErrorMessage}"
                       TextWrapping="Wrap" />

            <Grid Grid.Row="2"
                  Margin="0,18,0,0">
                <ListBox ItemsSource="{Binding Categories}"
                         SelectedItem="{Binding SelectedCategory}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="18"
                                    Margin="0,0,0,14"
                                    Background="#7440A7"
                                    BorderBrush="#A97AD4"
                                    BorderThickness="1"
                                    CornerRadius="24">
                                <StackPanel>
                                    <TextBlock FontSize="22"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource LltLightTextBrush}"
                                               Text="{Binding Name}" />
                                    <TextBlock Margin="0,12,0,0"
                                               Foreground="#EEE5F8"
                                               Text="{Binding DescriptionText}"
                                               TextWrapping="Wrap" />
                                    <Border Margin="0,14,0,0"
                                            Padding="12"
                                            Background="#220A2C"
                                            CornerRadius="18">
                                        <TextBlock Foreground="#E7D8F7"
                                                   Text="{Binding MetaText}"
                                                   TextWrapping="Wrap" />
                                    </Border>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Padding="28"
                        Background="#C5FFFFFF"
                        BorderBrush="#4EFFFFFF"
                        BorderThickness="1"
                        CornerRadius="24"
                        Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="18"
                               Foreground="{StaticResource LltInkSoftBrush}"
                               Text="Категории пока не созданы. Добавь первую, чтобы каталог стал управляемым."
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </Border>

                <Border Padding="28"
                        Background="#C5FFFFFF"
                        BorderBrush="#4EFFFFFF"
                        BorderThickness="1"
                        CornerRadius="24"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="18"
                               Foreground="{StaticResource LltInkSoftBrush}"
                               Text="Загружаем категории..."
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Column="1"
                Padding="24"
                Background="#7A43AE"
                BorderBrush="#A97AD4"
                BorderThickness="1"
                CornerRadius="28">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource LltLightTextBrush}"
                               Text="{Binding EditorTitle}" />

                    <TextBlock Margin="0,12,0,0"
                               Foreground="#EAFFD8"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap" />

                    <TextBlock Margin="0,8,0,0"
                               Foreground="#FFE2E2"
                               Text="{Binding ErrorMessage}"
                               TextWrapping="Wrap" />

                    <TextBlock Margin="0,20,0,8"
                               Foreground="{StaticResource LltLightTextBrush}"
                               Text="Название категории" />
                    <TextBox Style="{StaticResource LltTextBoxStyle}"
                             Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,18,0,8"
                               Foreground="{StaticResource LltLightTextBrush}"
                               Text="Описание" />
                    <TextBox MinHeight="180"
                             Style="{StaticResource LltTextBoxStyle}"
                             AcceptsReturn="True"
                             Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />

                    <Border Margin="0,18,0,0"
                            Padding="14"
                            Background="#220A2C"
                            CornerRadius="18">
                        <TextBlock Foreground="#E7D8F7"
                                   Text="Категории используются в фильтрах каталога, карточках курсов и аналитике. Если категория уже назначена курсам, удаление может быть недоступно."
                                   TextWrapping="Wrap" />
                    </Border>

                    <DockPanel Margin="0,24,0,0"
                               LastChildFill="False">
                        <Button DockPanel.Dock="Left"
                                Width="190"
                                Style="{StaticResource LltAccentButtonStyle}"
                                Command="{Binding SaveCommand}"
                                Content="{Binding SaveButtonText}" />
                        <Button DockPanel.Dock="Right"
                                Width="170"
                                Margin="10,0,0,0"
                                Style="{StaticResource LltDangerButtonStyle}"
                                Click="DeleteCategoryButton_OnClick"
                                Content="Удалить категорию"
                                IsEnabled="{Binding IsExistingCategory}" />
                    </DockPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
