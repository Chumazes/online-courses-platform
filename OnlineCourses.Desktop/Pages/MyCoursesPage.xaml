<Page x:Class="OnlineCourses.Desktop.Pages.MyCoursesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="MyCoursesPage">
    <Grid Margin="26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="24"
                Background="#7A43AE"
                BorderBrush="#A97AD4"
                BorderThickness="1"
                CornerRadius="28">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Width="64"
                        Height="64"
                        Margin="0,0,18,0"
                        CornerRadius="20"
                        ClipToBounds="True">
                    <Image Source="/Assets/mascot.jpg" Stretch="UniformToFill" />
                </Border>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center">
                    <TextBlock FontSize="32"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource LltLightTextBrush}"
                               Text="Мои курсы" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#E7D8F7"
                               Text="Личный кабинет студента: прогресс, активные записи и готовые маршруты обучения." />
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1"
                    Margin="6,12,0,0">
            <TextBlock Foreground="#9A1C30"
                       Text="{Binding ErrorMessage}"
                       TextWrapping="Wrap" />
            <TextBlock Margin="0,8,0,0"
                       Foreground="#2B6B22"
                       Text="{Binding StatusMessage}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="2"
              Margin="0,18,0,18">
            <ListBox x:Name="MyCoursesList"
                     ItemsSource="{Binding Courses}"
                     MouseDoubleClick="MyCoursesList_OnMouseDoubleClick"
                     SelectedItem="{Binding SelectedCourse}">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Width" Value="320" />
                        <Setter Property="Margin" Value="0,0,14,14" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border MinHeight="268"
                                Padding="18"
                                Background="#7641AB"
                                BorderBrush="#A97AD4"
                                BorderThickness="1"
                                CornerRadius="24">
                            <StackPanel>
                                <DockPanel LastChildFill="False">
                                    <TextBlock DockPanel.Dock="Left"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource LltLightTextBrush}"
                                               Text="{Binding Title}" />
                                    <Border DockPanel.Dock="Right"
                                            Padding="10,4"
                                            Background="#F2ECF9"
                                            CornerRadius="14">
                                        <TextBlock Foreground="{StaticResource LltInkBrush}"
                                                   Text="{Binding StatusText}" />
                                    </Border>
                                </DockPanel>

                                <TextBlock Margin="0,14,0,0"
                                           Foreground="#E8DCF5"
                                           Text="{Binding EnrollmentCaption}" />

                                <TextBlock Margin="0,8,0,0"
                                           Foreground="#E8DCF5"
                                           Text="{Binding ProgressCaption}" />

                                <TextBlock Margin="0,8,0,0"
                                           Foreground="#E8DCF5"
                                           Text="{Binding LessonsCaption}" />

                                <ProgressBar Height="12"
                                             Margin="0,16,0,0"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="{Binding OverallProgress, Mode=OneWay}" />

                                <Border Margin="0,18,0,0"
                                        Padding="12"
                                        Background="#200A2B"
                                        CornerRadius="18">
                                    <StackPanel>
                                        <TextBlock Foreground="#DCC9EE"
                                                   Text="{Binding ProgressCaption}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="#DCC9EE"
                                                   Text="{Binding LessonsCaption}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border Padding="28"
                    Background="#C5FFFFFF"
                    BorderBrush="#4EFFFFFF"
                    BorderThickness="1"
                    CornerRadius="24"
                    Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="18"
                           Foreground="{StaticResource LltInkSoftBrush}"
                           Text="Вы пока не записаны ни на один курс."
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
            </Border>

            <Border Padding="28"
                    Background="#C5FFFFFF"
                    BorderBrush="#4EFFFFFF"
                    BorderThickness="1"
                    CornerRadius="24"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="18"
                           Foreground="{StaticResource LltInkSoftBrush}"
                           Text="Загружаем ваши курсы..."
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
            </Border>
        </Grid>

        <DockPanel Grid.Row="3"
                   LastChildFill="False">
            <Button DockPanel.Dock="Left"
                    Width="220"
                    Style="{StaticResource LltLightButtonStyle}"
                    Click="UnenrollButton_OnClick"
                    Content="{Binding UnenrollButtonText}" />

            <Button DockPanel.Dock="Right"
                    Width="220"
                    Style="{StaticResource LltAccentButtonStyle}"
                    Command="{Binding OpenCourseCommand}"
                    Content="Открыть курс" />
        </DockPanel>
    </Grid>
</Page>
