<Page x:Class="OnlineCourses.Desktop.Pages.MyCoursesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="MyCoursesPage">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   FontSize="26"
                   FontWeight="SemiBold"
                   Text="Мои курсы" />

        <TextBlock Grid.Row="1"
                   Margin="0,12,0,0"
                   Foreground="#B91C1C"
                   Text="{Binding ErrorMessage}"
                   TextWrapping="Wrap" />

        <Grid Grid.Row="2"
              Margin="0,16,0,14">
            <ListBox x:Name="MyCoursesList"
                     ItemsSource="{Binding Courses}"
                     MouseDoubleClick="MyCoursesList_OnMouseDoubleClick"
                     SelectedItem="{Binding SelectedCourse}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="16"
                                Margin="0,0,0,10"
                                Background="White"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                CornerRadius="10">
                            <StackPanel>
                                <DockPanel LastChildFill="False">
                                    <TextBlock DockPanel.Dock="Left"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="{Binding Title}" />
                                    <Border DockPanel.Dock="Right"
                                            Padding="8,3"
                                            Background="#EFF6FF"
                                            CornerRadius="12">
                                        <TextBlock Foreground="#1D4ED8"
                                                   Text="{Binding StatusText}" />
                                    </Border>
                                </DockPanel>

                                <TextBlock Margin="0,10,0,0"
                                           Foreground="#6B7280"
                                           Text="{Binding EnrollmentCaption}" />

                                <ProgressBar Height="10"
                                             Margin="0,14,0,0"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="{Binding OverallProgress, Mode=OneWay}" />

                                <TextBlock Margin="0,8,0,0"
                                           Foreground="#374151"
                                           Text="{Binding ProgressCaption}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border Padding="24"
                    Background="#F9FAFB"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="12"
                    Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="16"
                           Foreground="#4B5563"
                           Text="Вы пока не записаны ни на один курс."
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
            </Border>

            <Border Padding="24"
                    Background="#F9FAFB"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="12"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="16"
                           Foreground="#4B5563"
                           Text="Загружаем ваши курсы..."
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
            </Border>
        </Grid>

        <Button Grid.Row="3"
                Width="170"
                Height="38"
                HorizontalAlignment="Right"
                Background="#111827"
                Foreground="White"
                Command="{Binding OpenCourseCommand}"
                Content="Открыть курс" />
    </Grid>
</Page>
