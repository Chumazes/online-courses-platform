<Page x:Class="OnlineCourses.Desktop.Pages.ManageLessonsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="ManageLessonsPage">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.05*" />
            <ColumnDefinition Width="1.2*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0"
              Margin="0,0,18,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0"
                       LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock FontSize="26"
                               FontWeight="SemiBold"
                               Text="Уроки секции" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#4B5563"
                               Text="{Binding SectionTitle}" />
                </StackPanel>

                <Button DockPanel.Dock="Right"
                        Width="150"
                        Height="38"
                        Background="#111827"
                        Foreground="White"
                        Click="CreateLessonButton_OnClick"
                        Content="Новый урок" />
            </DockPanel>

            <TextBlock Grid.Row="1"
                       Margin="0,12,0,0"
                       Foreground="#B91C1C"
                       Text="{Binding ErrorMessage}"
                       TextWrapping="Wrap" />

            <Grid Grid.Row="2"
                  Margin="0,16,0,0">
                <ListBox ItemsSource="{Binding Lessons}"
                         SelectedItem="{Binding SelectedLesson}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="14"
                                    Margin="0,0,0,10"
                                    Background="White"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <StackPanel>
                                    <DockPanel LastChildFill="False">
                                        <TextBlock DockPanel.Dock="Left"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Title}" />
                                        <Border DockPanel.Dock="Right"
                                                Padding="8,3"
                                                Background="#EFF6FF"
                                                CornerRadius="12">
                                            <TextBlock Foreground="#1D4ED8"
                                                       Text="{Binding OrderText}" />
                                        </Border>
                                    </DockPanel>

                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="#374151"
                                               Text="{Binding Content}"
                                               TextTrimming="CharacterEllipsis" />

                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="#6B7280"
                                               Text="{Binding MetaText}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Padding="24"
                        Background="#F9FAFB"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="12"
                        Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="16"
                               Foreground="#4B5563"
                               Text="У этой секции пока нет уроков."
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </Border>

                <Border Padding="24"
                        Background="#F9FAFB"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="12"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="16"
                               Foreground="#4B5563"
                               Text="Загружаем уроки..."
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Column="1"
                Padding="22"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Text="{Binding EditorTitle}" />

                    <TextBlock Margin="0,14,0,0"
                               Foreground="#047857"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap" />

                    <TextBlock Margin="0,8,0,0"
                               Foreground="#B91C1C"
                               Text="{Binding ErrorMessage}"
                               TextWrapping="Wrap" />

                    <TextBlock Margin="0,20,0,0"
                               FontWeight="SemiBold"
                               Text="Название урока" />
                    <TextBox Margin="0,8,0,0"
                             Padding="12,8"
                             Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,18,0,0"
                               FontWeight="SemiBold"
                               Text="Содержание" />
                    <TextBox MinHeight="120"
                             Margin="0,8,0,0"
                             Padding="12"
                             AcceptsReturn="True"
                             Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />

                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Margin="0,0,10,0">
                            <TextBlock FontWeight="SemiBold"
                                       Text="Тип урока" />
                            <ComboBox Margin="0,8,0,0"
                                      ItemsSource="{Binding LessonTypes}"
                                      SelectedItem="{Binding LessonType}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Margin="10,0,0,0">
                            <TextBlock FontWeight="SemiBold"
                                       Text="Порядок в секции" />
                            <TextBox Margin="0,8,0,0"
                                     Padding="12,8"
                                     Text="{Binding LessonOrder, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Margin="0,0,10,0">
                            <TextBlock FontWeight="SemiBold"
                                       Text="Видео URL" />
                            <TextBox Margin="0,8,0,0"
                                     Padding="12,8"
                                     Text="{Binding VideoUrl, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Margin="10,0,0,0">
                            <TextBlock FontWeight="SemiBold"
                                       Text="Длительность (мин)" />
                            <TextBox Margin="0,8,0,0"
                                     Padding="12,8"
                                     Text="{Binding DurationMinutes, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>

                    <CheckBox Margin="0,18,0,0"
                              Content="Бесплатный урок"
                              IsChecked="{Binding IsFree}" />

                    <Border Margin="0,18,0,0"
                            Padding="14"
                            Background="#F9FAFB"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="10">
                        <StackPanel>
                            <DockPanel LastChildFill="False">
                                <TextBlock DockPanel.Dock="Left"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Text="Файл урока" />
                                <Button DockPanel.Dock="Right"
                                        Width="150"
                                        Height="36"
                                        Click="UploadLessonFileButton_OnClick"
                                        Content="{Binding UploadButtonText}"
                                        IsEnabled="{Binding CanUploadFile}" />
                            </DockPanel>

                            <StackPanel Margin="0,12,0,0"
                                        Visibility="{Binding HasUploadedFile, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding UploadedFileName}" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="#6B7280"
                                           Text="{Binding UploadedFileSizeText}" />
                                <Button Width="140"
                                        Height="34"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Left"
                                        Background="#E5E7EB"
                                        BorderBrush="#D1D5DB"
                                        Click="OpenUploadedFileButton_OnClick"
                                        Content="Открыть файл" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <DockPanel Margin="0,24,0,0"
                               LastChildFill="False">
                        <Button DockPanel.Dock="Left"
                                Width="170"
                                Height="40"
                                Background="#111827"
                                Foreground="White"
                                Command="{Binding SaveCommand}"
                                Content="{Binding SaveButtonText}" />
                        <Button DockPanel.Dock="Right"
                                Width="150"
                                Height="40"
                                Background="#FEE2E2"
                                BorderBrush="#FCA5A5"
                                Foreground="#B91C1C"
                                Click="DeleteLessonButton_OnClick"
                                Content="Удалить урок"
                                IsEnabled="{Binding IsExistingLesson}" />
                    </DockPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
