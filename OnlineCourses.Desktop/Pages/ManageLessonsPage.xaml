<Page x:Class="OnlineCourses.Desktop.Pages.ManageLessonsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="ManageLessonsPage">
    <Grid Margin="26">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.05*" />
            <ColumnDefinition Width="1.15*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0"
              Margin="0,0,18,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="22"
                    Background="#7A43AE"
                    BorderBrush="#A97AD4"
                    BorderThickness="1"
                    CornerRadius="28">
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock FontSize="30"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource LltLightTextBrush}"
                                   Text="Уроки секции" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="#E7D8F7"
                                   Text="{Binding SectionTitle}" />
                    </StackPanel>
                    <Button DockPanel.Dock="Right"
                            Width="170"
                            Style="{StaticResource LltLightButtonStyle}"
                            Click="CreateLessonButton_OnClick"
                            Content="Новый урок" />
                </DockPanel>
            </Border>

            <TextBlock Grid.Row="1"
                       Margin="6,12,0,0"
                       Foreground="#9A1C30"
                       Text="{Binding ErrorMessage}"
                       TextWrapping="Wrap" />

            <Grid Grid.Row="2"
                  Margin="0,18,0,0">
                <ListBox ItemsSource="{Binding Lessons}"
                         SelectedItem="{Binding SelectedLesson}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="18"
                                    Margin="0,0,0,14"
                                    Background="#7440A7"
                                    BorderBrush="#A97AD4"
                                    BorderThickness="1"
                                    CornerRadius="24">
                                <StackPanel>
                                    <DockPanel LastChildFill="False">
                                        <TextBlock DockPanel.Dock="Left"
                                                   FontSize="22"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource LltLightTextBrush}"
                                                   Text="{Binding Title}" />
                                        <Border DockPanel.Dock="Right"
                                                Padding="10,4"
                                                Background="#F4EEFA"
                                                CornerRadius="14">
                                            <TextBlock Foreground="{StaticResource LltInkBrush}"
                                                       Text="{Binding OrderText}" />
                                        </Border>
                                    </DockPanel>

                                    <TextBlock Margin="0,12,0,0"
                                               Foreground="#EEE5F8"
                                               Text="{Binding Content}"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="Wrap" />

                                    <Border Margin="0,14,0,0"
                                            Padding="12"
                                            Background="#220A2C"
                                            CornerRadius="18">
                                        <TextBlock Foreground="#E7D8F7"
                                                   Text="{Binding MetaText}" />
                                    </Border>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Padding="28"
                        Background="#C5FFFFFF"
                        BorderBrush="#4EFFFFFF"
                        BorderThickness="1"
                        CornerRadius="24"
                        Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="18"
                               Foreground="{StaticResource LltInkSoftBrush}"
                               Text="У этой секции пока нет уроков."
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </Border>

                <Border Padding="28"
                        Background="#C5FFFFFF"
                        BorderBrush="#4EFFFFFF"
                        BorderThickness="1"
                        CornerRadius="24"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="18"
                               Foreground="{StaticResource LltInkSoftBrush}"
                               Text="Загружаем уроки..."
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Column="1"
                Padding="24"
                Background="#7A43AE"
                BorderBrush="#A97AD4"
                BorderThickness="1"
                CornerRadius="28">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource LltLightTextBrush}"
                               Text="{Binding EditorTitle}" />

                    <TextBlock Margin="0,12,0,0"
                               Foreground="#EAFFD8"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap" />

                    <TextBlock Margin="0,8,0,0"
                               Foreground="#FFE2E2"
                               Text="{Binding ErrorMessage}"
                               TextWrapping="Wrap" />

                    <TextBlock Margin="0,20,0,8"
                               Foreground="{StaticResource LltLightTextBrush}"
                               Text="Название урока" />
                    <TextBox Style="{StaticResource LltTextBoxStyle}"
                             Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,18,0,8"
                               Foreground="{StaticResource LltLightTextBrush}"
                               Text="Содержимое" />
                    <TextBox MinHeight="140"
                             Style="{StaticResource LltTextBoxStyle}"
                             AcceptsReturn="True"
                             Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />

                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Margin="0,0,10,0">
                            <TextBlock Foreground="{StaticResource LltLightTextBrush}"
                                       Text="Тип урока" />
                            <ComboBox Margin="0,8,0,0"
                                      Style="{StaticResource LltComboBoxStyle}"
                                      ItemsSource="{Binding LessonTypes}"
                                      SelectedItem="{Binding LessonType}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Margin="10,0,0,0">
                            <TextBlock Foreground="{StaticResource LltLightTextBrush}"
                                       Text="Порядок в секции" />
                            <TextBox Margin="0,8,0,0"
                                     Style="{StaticResource LltTextBoxStyle}"
                                     Text="{Binding LessonOrder, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Margin="0,0,10,0">
                            <TextBlock Foreground="{StaticResource LltLightTextBrush}"
                                       Text="Видео URL" />
                            <TextBox Margin="0,8,0,0"
                                     Style="{StaticResource LltTextBoxStyle}"
                                     Text="{Binding VideoUrl, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Margin="10,0,0,0">
                            <TextBlock Foreground="{StaticResource LltLightTextBrush}"
                                       Text="Длительность (мин)" />
                            <TextBox Margin="0,8,0,0"
                                     Style="{StaticResource LltTextBoxStyle}"
                                     Text="{Binding DurationMinutes, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>

                    <CheckBox Margin="0,18,0,0"
                              Foreground="{StaticResource LltLightTextBrush}"
                              Content="Бесплатный урок"
                              IsChecked="{Binding IsFree}" />

                    <Border Margin="0,20,0,0"
                            Padding="18"
                            Background="#200A2B"
                            BorderBrush="#9C71C8"
                            BorderThickness="1"
                            CornerRadius="20">
                        <StackPanel>
                            <DockPanel LastChildFill="False">
                                <TextBlock DockPanel.Dock="Left"
                                           VerticalAlignment="Center"
                                           FontSize="18"
                                           Foreground="{StaticResource LltLightTextBrush}"
                                           Text="Файл урока" />
                                <Button DockPanel.Dock="Right"
                                        Width="170"
                                        Style="{StaticResource LltLightButtonStyle}"
                                        Click="UploadLessonFileButton_OnClick"
                                        Content="{Binding UploadButtonText}"
                                        IsEnabled="{Binding CanUploadFile}" />
                            </DockPanel>

                            <StackPanel Margin="0,14,0,0"
                                        Visibility="{Binding HasUploadedFile, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock FontWeight="SemiBold"
                                           Foreground="{StaticResource LltLightTextBrush}"
                                           Text="{Binding UploadedFileName}" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="#E7D8F7"
                                           Text="{Binding UploadedFileSizeText}" />

                                <WrapPanel Margin="0,12,0,0">
                                    <Button Width="170"
                                            Margin="0,0,10,0"
                                            Style="{StaticResource LltPrimaryButtonStyle}"
                                            Click="OpenUploadedFileButton_OnClick"
                                            Content="Открыть файл" />
                                    <Button Width="170"
                                            Style="{StaticResource LltLightButtonStyle}"
                                            Click="DownloadUploadedFileButton_OnClick"
                                            Content="Скачать файл" />
                                </WrapPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <DockPanel Margin="0,24,0,0"
                               LastChildFill="False">
                        <Button DockPanel.Dock="Left"
                                Width="180"
                                Style="{StaticResource LltAccentButtonStyle}"
                                Command="{Binding SaveCommand}"
                                Content="{Binding SaveButtonText}" />
                        <Button DockPanel.Dock="Right"
                                Width="170"
                                Margin="10,0,0,0"
                                Style="{StaticResource LltDangerButtonStyle}"
                                Click="DeleteLessonButton_OnClick"
                                Content="Удалить урок"
                                IsEnabled="{Binding IsExistingLesson}" />
                    </DockPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
