<Page x:Class="OnlineCourses.Desktop.Pages.CourseDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="CourseDetailsPage">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="26">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="26"
                    Background="#7A43AE"
                    BorderBrush="#A97AD4"
                    BorderThickness="1"
                    CornerRadius="30">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="220" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Margin="0,0,24,0">
                        <TextBlock FontSize="34"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource LltLightTextBrush}"
                                   Text="{Binding Title}"
                                   TextWrapping="Wrap" />

                        <TextBlock Margin="0,16,0,0"
                                   FontSize="16"
                                   Foreground="#EBDDFA"
                                   Text="{Binding Description}"
                                   TextWrapping="Wrap" />

                        <WrapPanel Margin="0,18,0,0">
                            <Border Padding="12,5"
                                    Margin="0,0,10,10"
                                    Background="#F4EEFA"
                                    CornerRadius="16">
                                <TextBlock Foreground="{StaticResource LltInkBrush}"
                                           Text="{Binding Level}" />
                            </Border>

                            <Border Padding="12,5"
                                    Margin="0,0,10,10"
                                    Background="#63E62E"
                                    CornerRadius="16">
                                <TextBlock Foreground="{StaticResource LltAccentDarkBrush}"
                                           Text="{Binding Price}" />
                            </Border>

                            <Border Padding="12,5"
                                    Margin="0,0,10,10"
                                    Background="#F4EEFA"
                                    CornerRadius="16">
                                <TextBlock Foreground="{StaticResource LltInkBrush}"
                                           Text="{Binding CategoryName}" />
                            </Border>
                        </WrapPanel>

                        <TextBlock Margin="0,10,0,0"
                                   Foreground="#EBDDFA"
                                   Text="{Binding AuthorName, StringFormat=Автор: {0}}" />

                        <WrapPanel Margin="0,22,0,0">
                            <Button Width="210"
                                    Margin="0,0,14,10"
                                    Style="{StaticResource LltAccentButtonStyle}"
                                    Command="{Binding EnrollCommand}"
                                    Content="{Binding EnrollButtonText}" />

                            <Border Padding="16,10"
                                    Margin="0,0,0,10"
                                    Background="#220A2C"
                                    BorderBrush="#9C71C8"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Visibility="{Binding ShowCourseProgress, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Foreground="#EBDDFA"
                                           Text="{Binding CourseProgressCaption}" />
                            </Border>
                        </WrapPanel>

                        <TextBlock Margin="0,10,0,0"
                                   Foreground="#EAFFD8"
                                   Text="{Binding EnrollmentStatusMessage}"
                                   TextWrapping="Wrap" />

                        <TextBlock Margin="0,8,0,0"
                                   Foreground="#FFE2E2"
                                   Text="{Binding EnrollmentErrorMessage}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="#18071F"
                            BorderBrush="#A97AD4"
                            BorderThickness="1"
                            CornerRadius="24">
                        <StackPanel Margin="18"
                                    VerticalAlignment="Center">
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource LltLightTextBrush}"
                                       Text="Прогресс" />

                            <ProgressBar Height="12"
                                         Margin="0,18,0,0"
                                         Minimum="0"
                                         Maximum="100"
                                         Value="{Binding OverallProgress, Mode=OneWay}" />

                            <TextBlock Margin="0,10,0,0"
                                       Foreground="#EBDDFA"
                                       Text="{Binding OverallProgress, StringFormat=Общий прогресс: {0}%}" />

                            <TextBlock Margin="0,18,0,0"
                                       Foreground="#D2BCE9"
                                       Text="Low-Level to Top"
                                       TextAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <TextBlock Grid.Row="1"
                       Margin="6,14,0,0"
                       Foreground="{StaticResource LltInkSoftBrush}"
                       Text="Загружаем структуру курса..."
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />

            <TextBlock Grid.Row="2"
                       Margin="6,10,0,0"
                       Foreground="#9A1C30"
                       Text="{Binding ErrorMessage}"
                       TextWrapping="Wrap" />

            <Border Grid.Row="3"
                    Margin="0,18,0,0"
                    Padding="24"
                    Background="#C5FFFFFF"
                    BorderBrush="#4EFFFFFF"
                    BorderThickness="1"
                    CornerRadius="28">
                <StackPanel>
                    <TextBlock FontSize="28"
                               FontWeight="SemiBold"
                               Text="Программа курса" />

                    <TextBlock Margin="0,10,0,0"
                               Foreground="{StaticResource LltInkSoftBrush}"
                               Text="Реальные разделы и уроки, которые пришли из API и уже доступны внутри desktop-клиента."
                               TextWrapping="Wrap" />

                    <Border Margin="0,18,0,0"
                            Padding="18"
                            Background="#EEE6F6"
                            CornerRadius="20"
                            Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Foreground="{StaticResource LltInkSoftBrush}"
                                   Text="Разделы пока не добавлены."
                                   TextWrapping="Wrap" />
                    </Border>

                    <ItemsControl Margin="0,18,0,0"
                                  ItemsSource="{Binding Sections}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,16"
                                        Padding="20"
                                        Background="#7340A6"
                                        BorderBrush="#A97AD4"
                                        BorderThickness="1"
                                        CornerRadius="24">
                                    <StackPanel>
                                        <DockPanel LastChildFill="False">
                                            <TextBlock DockPanel.Dock="Left"
                                                       FontSize="22"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource LltLightTextBrush}"
                                                       Text="{Binding Title}" />
                                            <Border DockPanel.Dock="Right"
                                                    Padding="10,4"
                                                    Background="#F4EEFA"
                                                    CornerRadius="16">
                                                <TextBlock Foreground="{StaticResource LltInkBrush}"
                                                           Text="{Binding LessonsCaption}" />
                                            </Border>
                                        </DockPanel>

                                        <TextBlock Margin="0,10,0,0"
                                                   Foreground="#EEE5F8"
                                                   Text="{Binding Description}"
                                                   TextWrapping="Wrap" />

                                        <ItemsControl Margin="0,16,0,0"
                                                      ItemsSource="{Binding Lessons}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button x:Name="LessonButton"
                                                            Margin="0,0,0,12"
                                                            Padding="0"
                                                            Background="Transparent"
                                                            BorderBrush="Transparent"
                                                            Click="LessonButton_OnClick"
                                                            Cursor="Hand"
                                                            HorizontalContentAlignment="Stretch"
                                                            Tag="{Binding}">
                                                        <Border x:Name="LessonCardBorder"
                                                                Padding="16"
                                                                Background="#F6F1FB"
                                                                BorderBrush="#E4D6F1"
                                                                BorderThickness="1"
                                                                CornerRadius="20">
                                                            <StackPanel>
                                                                <DockPanel LastChildFill="False">
                                                                    <TextBlock DockPanel.Dock="Left"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{StaticResource LltInkBrush}"
                                                                               Text="{Binding Title}" />
                                                                    <Border DockPanel.Dock="Right"
                                                                            Padding="10,4"
                                                                            Background="#63E62E"
                                                                            CornerRadius="14">
                                                                        <TextBlock Foreground="{StaticResource LltAccentDarkBrush}"
                                                                                   Text="Открыть" />
                                                                    </Border>
                                                                </DockPanel>
                                                                <TextBlock Margin="0,8,0,0"
                                                                           Foreground="{StaticResource LltInkSoftBrush}"
                                                                           Text="{Binding MetaText}" />
                                                                <TextBlock Margin="0,8,0,0"
                                                                           Foreground="{StaticResource LltInkBrush}"
                                                                           Text="{Binding Content}"
                                                                           TextWrapping="Wrap" />
                                                            </StackPanel>
                                                        </Border>
                                                    </Button>
                                                    <DataTemplate.Triggers>
                                                        <Trigger SourceName="LessonButton" Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="LessonCardBorder" Property="Background" Value="#FFF9FF" />
                                                            <Setter TargetName="LessonCardBorder" Property="BorderBrush" Value="#A97AD4" />
                                                        </Trigger>
                                                        <Trigger SourceName="LessonButton" Property="IsPressed" Value="True">
                                                            <Setter TargetName="LessonCardBorder" Property="Background" Value="#EDE2F8" />
                                                            <Setter TargetName="LessonCardBorder" Property="BorderBrush" Value="#8B59C0" />
                                                        </Trigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Margin="0,28,0,0"
                            Padding="22"
                            Background="#EEE6F6"
                            BorderBrush="#D9C9E8"
                            BorderThickness="1"
                            CornerRadius="24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock FontSize="24"
                                           FontWeight="SemiBold"
                                           Text="Отзывы и рейтинг" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource LltInkSoftBrush}"
                                           Text="{Binding ReviewCountText}" />
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Padding="18,10"
                                    Background="#6F4B96"
                                    BorderBrush="#B494D4"
                                    BorderThickness="1"
                                    CornerRadius="20">
                                <StackPanel>
                                    <TextBlock HorizontalAlignment="Center"
                                               FontSize="24"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource LltLightTextBrush}"
                                               Text="{Binding RatingSummaryText}" />
                                    <TextBlock Margin="0,6,0,0"
                                               HorizontalAlignment="Center"
                                               Foreground="#EEE5F8"
                                               Text="{Binding TotalReviews, StringFormat=Всего отзывов: {0}}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Margin="0,18,0,0"
                            Padding="22"
                            Background="#6F4B96"
                            BorderBrush="#B494D4"
                            BorderThickness="1"
                            CornerRadius="24">
                        <StackPanel>
                            <TextBlock FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource LltLightTextBrush}"
                                       Text="Ваш отзыв" />

                            <TextBlock Margin="0,10,0,0"
                                       Foreground="#EEE5F8"
                                       Text="{Binding OwnReviewStateText}"
                                       TextWrapping="Wrap" />

                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            Margin="0,0,18,0">
                                    <TextBlock Foreground="{StaticResource LltLightTextBrush}"
                                               Text="Оценка" />
                                    <ComboBox Margin="0,8,0,0"
                                              Style="{StaticResource LltComboBoxStyle}"
                                              ItemsSource="{Binding RatingOptions}"
                                              SelectedItem="{Binding SelectedRating}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Foreground="{StaticResource LltLightTextBrush}"
                                               Text="Комментарий" />
                                    <TextBox MinHeight="120"
                                             Margin="0,8,0,0"
                                             Style="{StaticResource LltTextBoxStyle}"
                                             AcceptsReturn="True"
                                             Text="{Binding ReviewComment, UpdateSourceTrigger=PropertyChanged}"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Margin="0,14,0,0"
                                       Foreground="#EAFFD8"
                                       Text="{Binding ReviewStatusMessage}"
                                       TextWrapping="Wrap" />

                            <TextBlock Margin="0,8,0,0"
                                       Foreground="#FFE2E2"
                                       Text="{Binding ReviewErrorMessage}"
                                       TextWrapping="Wrap" />

                            <DockPanel Margin="0,18,0,0"
                                       LastChildFill="False">
                                <Button DockPanel.Dock="Left"
                                        Width="180"
                                        Style="{StaticResource LltAccentButtonStyle}"
                                        Command="{Binding SaveReviewCommand}"
                                        Content="{Binding ReviewButtonText}" />

                                <Button DockPanel.Dock="Right"
                                        Width="170"
                                        Margin="10,0,0,0"
                                        Style="{StaticResource LltDangerButtonStyle}"
                                        Command="{Binding DeleteReviewCommand}"
                                        Content="Удалить отзыв"
                                        Visibility="{Binding HasOwnReview, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock Margin="0,18,0,0"
                               Foreground="{StaticResource LltInkSoftBrush}"
                               Text="Загружаем отзывы..."
                               Visibility="{Binding IsReviewsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <TextBlock Margin="0,10,0,0"
                               Foreground="#9A1C30"
                               Text="{Binding ReviewsErrorMessage}"
                               TextWrapping="Wrap" />

                    <Border Margin="0,16,0,0"
                            Padding="18"
                            Background="#F4EEF9"
                            BorderBrush="#D9C9E8"
                            BorderThickness="1"
                            CornerRadius="20"
                            Visibility="{Binding ShowReviewsEmptyState, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Foreground="{StaticResource LltInkSoftBrush}"
                                   Text="Пока нет опубликованных отзывов."
                                   TextWrapping="Wrap" />
                    </Border>

                    <ItemsControl Margin="0,18,0,0"
                                  ItemsSource="{Binding Reviews}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,14"
                                        Padding="18"
                                        Background="#F7F3FB"
                                        BorderBrush="#DCCDEB"
                                        BorderThickness="1"
                                        CornerRadius="22">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Grid Width="48"
                                              Height="48"
                                              Margin="0,0,14,0">
                                            <Border Background="#6F4B96"
                                                    CornerRadius="24" />
                                            <Image x:Name="ReviewAvatarImage"
                                                   Source="{Binding AvatarSource}"
                                                   Stretch="UniformToFill"
                                                   Visibility="{Binding HasAvatar, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <Image.Clip>
                                                    <EllipseGeometry Center="24,24"
                                                                     RadiusX="24"
                                                                     RadiusY="24" />
                                                </Image.Clip>
                                            </Image>
                                            <TextBlock x:Name="ReviewAvatarInitials"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource LltLightTextBrush}"
                                                       Text="{Binding Initials}"
                                                       Visibility="{Binding ShowInitials, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        </Grid>

                                        <StackPanel Grid.Column="1">
                                            <DockPanel LastChildFill="False">
                                                <TextBlock DockPanel.Dock="Left"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding UserName}" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           Foreground="#B17A00"
                                                           Text="{Binding RatingText}" />
                                            </DockPanel>

                                            <TextBlock Margin="0,6,0,0"
                                                       Foreground="{StaticResource LltInkSoftBrush}"
                                                       Text="{Binding ReviewDateText}" />

                                            <TextBlock Margin="0,10,0,0"
                                                       Foreground="{StaticResource LltInkBrush}"
                                                       Text="{Binding CommentText}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
