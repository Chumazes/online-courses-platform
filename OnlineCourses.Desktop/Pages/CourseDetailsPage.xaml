<Page x:Class="OnlineCourses.Desktop.Pages.CourseDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="CourseDetailsPage">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="22"
                    Background="White"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="12">
                <StackPanel>
                    <TextBlock FontSize="28"
                               FontWeight="SemiBold"
                               Text="{Binding Title}" />

                    <TextBlock Margin="0,16,0,0"
                               FontSize="16"
                               Foreground="#4B5563"
                               Text="{Binding Description}"
                               TextWrapping="Wrap" />

                    <WrapPanel Margin="0,18,0,0">
                        <Border Padding="10,4"
                                Margin="0,0,10,0"
                                Background="#EFF6FF"
                                CornerRadius="14">
                            <TextBlock Foreground="#1D4ED8"
                                       Text="{Binding Level}" />
                        </Border>

                        <Border Padding="10,4"
                                Margin="0,0,10,0"
                                Background="#ECFDF5"
                                CornerRadius="14">
                            <TextBlock Foreground="#047857"
                                       Text="{Binding Price}" />
                        </Border>

                        <Border Padding="10,4"
                                Margin="0,0,10,0"
                                Background="#F3E8FF"
                                CornerRadius="14">
                            <TextBlock Foreground="#7C3AED"
                                       Text="{Binding CategoryName}" />
                        </Border>
                    </WrapPanel>

                    <TextBlock Margin="0,18,0,0"
                               Foreground="#6B7280"
                               Text="{Binding AuthorName, StringFormat=Автор: {0}}" />

                    <StackPanel Margin="0,18,0,0">
                        <Button Width="190"
                                Height="38"
                                HorizontalAlignment="Left"
                                Background="#111827"
                                Foreground="White"
                                Command="{Binding EnrollCommand}"
                                Content="{Binding EnrollButtonText}" />

                        <TextBlock Margin="0,10,0,0"
                                   Foreground="#047857"
                                   Text="{Binding EnrollmentStatusMessage}"
                                   TextWrapping="Wrap" />

                        <TextBlock Margin="0,8,0,0"
                                   Foreground="#B91C1C"
                                   Text="{Binding EnrollmentErrorMessage}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Border Margin="0,18,0,0"
                            Padding="14"
                            Background="#F9FAFB"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="10"
                            Visibility="{Binding ShowCourseProgress, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="#111827"
                                       Text="{Binding CourseProgressCaption}" />

                            <ProgressBar Height="10"
                                         Margin="0,12,0,0"
                                         Minimum="0"
                                         Maximum="100"
                                         Value="{Binding OverallProgress, Mode=OneWay}" />

                            <TextBlock Margin="0,8,0,0"
                                       Foreground="#4B5563"
                                       Text="{Binding OverallProgress, StringFormat=Общий прогресс: {0}%}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <TextBlock Grid.Row="1"
                       Margin="0,16,0,0"
                       Foreground="#1D4ED8"
                       Text="Загружаем структуру курса..."
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />

            <TextBlock Grid.Row="2"
                       Margin="0,12,0,0"
                       Foreground="#B91C1C"
                       Text="{Binding ErrorMessage}"
                       TextWrapping="Wrap" />

            <Border Grid.Row="3"
                    Margin="0,16,0,0"
                    Padding="18"
                    Background="White"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="12">
                <StackPanel>
                    <TextBlock FontSize="20"
                               FontWeight="SemiBold"
                               Text="Программа курса" />

                    <TextBlock Margin="0,10,0,0"
                               Foreground="#6B7280"
                               Text="Здесь отображаются реальные разделы и уроки, которые пришли с API."
                               TextWrapping="Wrap" />

                    <TextBlock Margin="0,16,0,0"
                               Foreground="#6B7280"
                               Text="Разделы пока не добавлены."
                               Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <ItemsControl Margin="0,16,0,0"
                                  ItemsSource="{Binding Sections}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,14"
                                        Padding="16"
                                        Background="#F9FAFB"
                                        BorderBrush="#E5E7EB"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <StackPanel>
                                        <DockPanel LastChildFill="False">
                                            <TextBlock DockPanel.Dock="Left"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Title}" />
                                            <Border DockPanel.Dock="Right"
                                                    Padding="8,3"
                                                    Background="#E0F2FE"
                                                    CornerRadius="12">
                                                <TextBlock Foreground="#0369A1"
                                                           Text="{Binding LessonsCaption}" />
                                            </Border>
                                        </DockPanel>

                                        <TextBlock Margin="0,8,0,0"
                                                   Foreground="#6B7280"
                                                   Text="{Binding Description}"
                                                   TextWrapping="Wrap" />

                                        <ItemsControl Margin="0,12,0,0"
                                                      ItemsSource="{Binding Lessons}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button x:Name="LessonButton"
                                                            Margin="0,0,0,10"
                                                            Padding="0"
                                                            Background="Transparent"
                                                            BorderBrush="Transparent"
                                                            Click="LessonButton_OnClick"
                                                            Cursor="Hand"
                                                            HorizontalContentAlignment="Stretch"
                                                            Tag="{Binding}">
                                                        <Border x:Name="LessonCardBorder"
                                                                Padding="12"
                                                                Background="White"
                                                                BorderBrush="#E5E7EB"
                                                                BorderThickness="1"
                                                                CornerRadius="8">
                                                            <StackPanel>
                                                                <DockPanel LastChildFill="False">
                                                                    <TextBlock DockPanel.Dock="Left"
                                                                               FontWeight="SemiBold"
                                                                               Text="{Binding Title}" />
                                                                    <TextBlock DockPanel.Dock="Right"
                                                                               Foreground="#2563EB"
                                                                               Text="Открыть" />
                                                                </DockPanel>
                                                                <TextBlock Margin="0,6,0,0"
                                                                           Foreground="#6B7280"
                                                                           Text="{Binding MetaText}" />
                                                                <TextBlock Margin="0,6,0,0"
                                                                           Foreground="#4B5563"
                                                                           Text="{Binding Content}"
                                                                           TextWrapping="Wrap" />
                                                            </StackPanel>
                                                        </Border>
                                                    </Button>
                                                    <DataTemplate.Triggers>
                                                        <Trigger SourceName="LessonButton" Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="LessonCardBorder" Property="Background" Value="#F8FBFF" />
                                                            <Setter TargetName="LessonCardBorder" Property="BorderBrush" Value="#93C5FD" />
                                                        </Trigger>
                                                        <Trigger SourceName="LessonButton" Property="IsPressed" Value="True">
                                                            <Setter TargetName="LessonCardBorder" Property="Background" Value="#EFF6FF" />
                                                            <Setter TargetName="LessonCardBorder" Property="BorderBrush" Value="#60A5FA" />
                                                        </Trigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
