<Page x:Class="OnlineCourses.Desktop.Pages.WhyItPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="WhyItPage">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="26">
            <StackPanel>
                <Border Padding="28"
                        Background="#6F4B96"
                        BorderBrush="#B494D4"
                        BorderThickness="1"
                        CornerRadius="28">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="260" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Margin="0,0,24,0">
                            <TextBlock FontSize="34"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource LltLightTextBrush}"
                                       Text="Почему стоит попробовать себя в IT?" />
                            <TextBlock Margin="0,14,0,0"
                                       FontSize="18"
                                       Foreground="#EFE5F8"
                                       Text="IT — это не только про код. Это про умение решать задачи, строить понятные продукты и расти в профессии шаг за шагом. Low-Level to Top помогает пройти этот путь без хаоса и случайных тем."
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,12,0,0"
                                       Foreground="#EAFBDD"
                                       Text="Мы собрали курсы, прогресс, отзывы и управление в одной системе, чтобы путь в профессию был не абстрактным, а реальным."
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <Border Grid.Column="1"
                                Padding="16"
                                Background="#190A20"
                                BorderBrush="#B596D1"
                                BorderThickness="1"
                                CornerRadius="24">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock HorizontalAlignment="Center"
                                           Foreground="#E6D6F7"
                                           Text="LLT" />

                                <Border Grid.Row="1"
                                        Margin="0,12,0,12"
                                        CornerRadius="22"
                                        ClipToBounds="True">
                                    <Image Source="/Assets/mascot.jpg"
                                           Stretch="UniformToFill" />
                                </Border>

                                <TextBlock Grid.Row="2"
                                           HorizontalAlignment="Center"
                                           Foreground="#E6D6F7"
                                           Text="Low-Level to Top" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <WrapPanel Margin="0,18,0,0">
                    <Border Width="320"
                            Margin="0,0,18,18"
                            Padding="20"
                            Background="#F2EDF7"
                            BorderBrush="#D7C8E7"
                            BorderThickness="1"
                            CornerRadius="24">
                        <StackPanel>
                            <TextBlock FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource LltInkBrush}"
                                       Text="Понятный старт" />
                            <TextBlock Margin="0,12,0,0"
                                       Foreground="{StaticResource LltInkSoftBrush}"
                                       Text="Не нужно гадать, с чего начать. На платформе уже есть уровни сложности, маршруты и готовые сценарии обучения."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Width="320"
                            Margin="0,0,18,18"
                            Padding="20"
                            Background="#F2EDF7"
                            BorderBrush="#D7C8E7"
                            BorderThickness="1"
                            CornerRadius="24">
                        <StackPanel>
                            <TextBlock FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource LltInkBrush}"
                                       Text="Живая практика" />
                            <TextBlock Margin="0,12,0,0"
                                       Foreground="{StaticResource LltInkSoftBrush}"
                                       Text="Важно не просто читать материалы, а реально двигаться по урокам, видеть прогресс и возвращаться к обучению в удобном темпе."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Width="320"
                            Margin="0,0,0,18"
                            Padding="20"
                            Background="#F2EDF7"
                            BorderBrush="#D7C8E7"
                            BorderThickness="1"
                            CornerRadius="24">
                        <StackPanel>
                            <TextBlock FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource LltInkBrush}"
                                       Text="Рост без хаоса" />
                            <TextBlock Margin="0,12,0,0"
                                       Foreground="{StaticResource LltInkSoftBrush}"
                                       Text="Когда курсы, отзывы, преподаватели и прогресс живут в одной системе, меньше шансов потеряться и бросить обучение."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <Border Padding="24"
                        Background="#2A1238"
                        BorderBrush="#5C3880"
                        BorderThickness="1"
                        CornerRadius="24">
                    <StackPanel>
                        <TextBlock FontSize="26"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource LltLightTextBrush}"
                                   Text="Что уже умеет платформа" />
                        <WrapPanel Margin="0,18,0,0">
                            <Border Margin="0,0,14,14"
                                    Padding="14,10"
                                    Background="#7440A7"
                                    BorderBrush="#A97AD4"
                                    BorderThickness="1"
                                    CornerRadius="18">
                                <TextBlock Foreground="{StaticResource LltLightTextBrush}"
                                           Text="Каталог курсов и фильтры" />
                            </Border>
                            <Border Margin="0,0,14,14"
                                    Padding="14,10"
                                    Background="#7440A7"
                                    BorderBrush="#A97AD4"
                                    BorderThickness="1"
                                    CornerRadius="18">
                                <TextBlock Foreground="{StaticResource LltLightTextBrush}"
                                           Text="Прогресс по урокам" />
                            </Border>
                            <Border Margin="0,0,14,14"
                                    Padding="14,10"
                                    Background="#7440A7"
                                    BorderBrush="#A97AD4"
                                    BorderThickness="1"
                                    CornerRadius="18">
                                <TextBlock Foreground="{StaticResource LltLightTextBrush}"
                                           Text="Отзывы и модерация" />
                            </Border>
                            <Border Margin="0,0,14,14"
                                    Padding="14,10"
                                    Background="#7440A7"
                                    BorderBrush="#A97AD4"
                                    BorderThickness="1"
                                    CornerRadius="18">
                                <TextBlock Foreground="{StaticResource LltLightTextBrush}"
                                           Text="Панель преподавателя" />
                            </Border>
                            <Border Margin="0,0,0,14"
                                    Padding="14,10"
                                    Background="#7440A7"
                                    BorderBrush="#A97AD4"
                                    BorderThickness="1"
                                    CornerRadius="18">
                                <TextBlock Foreground="{StaticResource LltLightTextBrush}"
                                           Text="Роль администратора" />
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
