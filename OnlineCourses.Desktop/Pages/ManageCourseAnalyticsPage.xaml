<Page x:Class="OnlineCourses.Desktop.Pages.ManageCourseAnalyticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="ManageCourseAnalyticsPage">
    <Grid Margin="26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="24"
                Background="#7A43AE"
                BorderBrush="#A97AD4"
                BorderThickness="1"
                CornerRadius="28">
            <StackPanel>
                <TextBlock FontSize="30"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource LltLightTextBrush}"
                           Text="Аналитика курса" />
                <TextBlock Margin="0,8,0,0"
                           Foreground="#E7D8F7"
                           Text="{Binding Course.Title}" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="#E7D8F7"
                           Text="{Binding Course.MetaText}" />
                <TextBlock Margin="0,8,0,0"
                           Foreground="#EAFBDD"
                           Text="{Binding EngagementCaption}" />
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="1"
                   Margin="6,12,0,0"
                   Foreground="#9A1C30"
                   Text="{Binding ErrorMessage}"
                   TextWrapping="Wrap" />

        <ScrollViewer Grid.Row="2"
                      Margin="0,18,0,0"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <WrapPanel>
                    <Border Width="250"
                            Margin="0,0,16,16"
                            Padding="18"
                            Background="#7440A7"
                            BorderBrush="#A97AD4"
                            BorderThickness="1"
                            CornerRadius="24">
                        <StackPanel>
                            <TextBlock Foreground="#E7D8F7"
                                       Text="Студенты" />
                            <TextBlock Margin="0,10,0,0"
                                       FontSize="34"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource LltLightTextBrush}"
                                       Text="{Binding StudentCount}" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="#E7D8F7"
                                       Text="Все актуальные записи на курс" />
                        </StackPanel>
                    </Border>

                    <Border Width="250"
                            Margin="0,0,16,16"
                            Padding="18"
                            Background="#7440A7"
                            BorderBrush="#A97AD4"
                            BorderThickness="1"
                            CornerRadius="24">
                        <StackPanel>
                            <TextBlock Foreground="#E7D8F7"
                                       Text="Средний прогресс" />
                            <TextBlock Margin="0,10,0,0"
                                       FontSize="34"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource LltLightTextBrush}"
                                       Text="{Binding AverageProgress, StringFormat={}{0}%}" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="#E7D8F7"
                                       Text="По всем студентам на курсе" />
                        </StackPanel>
                    </Border>

                    <Border Width="250"
                            Margin="0,0,16,16"
                            Padding="18"
                            Background="#7440A7"
                            BorderBrush="#A97AD4"
                            BorderThickness="1"
                            CornerRadius="24">
                        <StackPanel>
                            <TextBlock Foreground="#E7D8F7"
                                       Text="Завершение" />
                            <TextBlock Margin="0,10,0,0"
                                       FontSize="34"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource LltLightTextBrush}"
                                       Text="{Binding CompletionRateCaption}" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="#E7D8F7"
                                       Text="{Binding CompletedStudentsCount, StringFormat=Завершили: {0}}" />
                        </StackPanel>
                    </Border>

                    <Border Width="250"
                            Margin="0,0,0,16"
                            Padding="18"
                            Background="#7440A7"
                            BorderBrush="#A97AD4"
                            BorderThickness="1"
                            CornerRadius="24">
                        <StackPanel>
                            <TextBlock Foreground="#E7D8F7"
                                       Text="Рейтинг" />
                            <TextBlock Margin="0,10,0,0"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource LltLightTextBrush}"
                                       Text="{Binding AverageRatingCaption}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="#E7D8F7"
                                       Text="{Binding ReviewsCaption}" />
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <Border Margin="0,0,0,16"
                        Padding="22"
                        Background="#7440A7"
                        BorderBrush="#A97AD4"
                        BorderThickness="1"
                        CornerRadius="24">
                    <StackPanel>
                        <TextBlock FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource LltLightTextBrush}"
                                   Text="Распределение оценок" />
                        <TextBlock Margin="0,14,0,0"
                                   Foreground="#E7D8F7"
                                   Text="{Binding RatingDistributionCaption}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Padding="22"
                        Background="#7440A7"
                        BorderBrush="#A97AD4"
                        BorderThickness="1"
                        CornerRadius="24">
                    <StackPanel>
                        <TextBlock FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource LltLightTextBrush}"
                                   Text="Студенты и прогресс" />

                        <ListBox Margin="0,18,0,0"
                                 ItemsSource="{Binding Students}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="18"
                                            Margin="0,0,0,14"
                                            Background="#220A2C"
                                            BorderBrush="#6E47A1"
                                            BorderThickness="1"
                                            CornerRadius="22">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Grid Width="52"
                                                  Height="52"
                                                  Margin="0,0,16,0">
                                                <Border Background="#6F4B96"
                                                        CornerRadius="26" />
                                                <Image Source="{Binding AvatarSource}"
                                                       Stretch="UniformToFill"
                                                       Visibility="{Binding HasAvatar, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <Image.Clip>
                                                        <EllipseGeometry Center="26,26"
                                                                         RadiusX="26"
                                                                         RadiusY="26" />
                                                    </Image.Clip>
                                                </Image>
                                                <TextBlock VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource LltLightTextBrush}"
                                                           Text="{Binding Initials}"
                                                           Visibility="{Binding ShowInitials, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            </Grid>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock FontSize="20"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource LltLightTextBrush}"
                                                           Text="{Binding UserName}" />
                                                <TextBlock Margin="0,8,0,0"
                                                           Foreground="#E7D8F7"
                                                           Text="{Binding EnrollmentCaption}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Foreground="#E7D8F7"
                                                           Text="{Binding ProgressCaption}" />
                                                <ProgressBar Height="10"
                                                             Margin="0,12,0,0"
                                                             Minimum="0"
                                                             Maximum="100"
                                                             Value="{Binding OverallProgress, Mode=OneWay}" />
                                            </StackPanel>

                                            <Border Grid.Column="2"
                                                    Margin="18,0,0,0"
                                                    Padding="10,4"
                                                    VerticalAlignment="Top"
                                                    Background="#F4EEFA"
                                                    CornerRadius="14">
                                                <TextBlock Foreground="{StaticResource LltInkBrush}"
                                                           Text="{Binding StatusText}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <Border Margin="0,16,0,0"
                        Padding="28"
                        Background="#C5FFFFFF"
                        BorderBrush="#4EFFFFFF"
                        BorderThickness="1"
                        CornerRadius="24"
                        Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="18"
                               Foreground="{StaticResource LltInkSoftBrush}"
                               Text="По курсу пока нет актуальных записей, поэтому метрики почти пусты."
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </Border>

                <Border Margin="0,16,0,0"
                        Padding="28"
                        Background="#C5FFFFFF"
                        BorderBrush="#4EFFFFFF"
                        BorderThickness="1"
                        CornerRadius="24"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="18"
                               Foreground="{StaticResource LltInkSoftBrush}"
                               Text="Загружаем аналитику курса..."
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
