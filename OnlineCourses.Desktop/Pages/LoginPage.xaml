<Page x:Class="OnlineCourses.Desktop.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="LoginPage">
    <Grid Background="#F3F4F6">
        <Border Width="420"
                Padding="28"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="12"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>
                <TextBlock FontSize="28"
                           FontWeight="SemiBold"
                           Text="{Binding ModeTitle}" />

                <TextBlock Margin="0,22,0,8"
                           FontWeight="Medium"
                           Text="Email" />
                <TextBox Height="34"
                         Padding="8,6"
                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />

                <StackPanel Margin="0,14,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowFullName}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock Margin="0,0,0,8"
                               FontWeight="Medium"
                               Text="ФИО" />
                    <TextBox Height="34"
                             Padding="8,6"
                             Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <TextBlock Margin="0,14,0,8"
                           FontWeight="Medium"
                           Text="Пароль" />
                <PasswordBox Height="34"
                             Padding="8,6"
                             PasswordChanged="PasswordBox_OnPasswordChanged" />

                <TextBlock Margin="0,12,0,0"
                           Foreground="#B91C1C"
                           Text="{Binding ErrorMessage}"
                           TextWrapping="Wrap" />

                <Button Height="40"
                        Margin="0,16,0,0"
                        Background="#111827"
                        Foreground="White"
                        Command="{Binding SubmitCommand}"
                        Content="{Binding ModeActionText}" />

                <Button Height="34"
                        Margin="0,10,0,0"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Foreground="#1D4ED8"
                        Command="{Binding ToggleModeCommand}"
                        Content="{Binding SwitchModeText}" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
