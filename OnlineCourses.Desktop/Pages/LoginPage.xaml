<Page x:Class="OnlineCourses.Desktop.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="LoginPage">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="18">
            <Border MaxWidth="720"
                    Padding="26"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#6E4A94"
                    BorderBrush="#B698D5"
                    BorderThickness="1"
                    CornerRadius="30">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Width="160"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Style="{StaticResource LltLightButtonStyle}"
                                Click="BackButton_OnClick"
                                Content="На витрину" />

                        <Border Grid.Column="1"
                                HorizontalAlignment="Center"
                                Padding="32,12"
                                Background="#FAF7FD"
                                BorderBrush="#DED0ED"
                                BorderThickness="1"
                                CornerRadius="26">
                            <TextBlock FontSize="24"
                                       Foreground="{StaticResource LltInkBrush}"
                                       Text="{Binding ModeTitle}" />
                        </Border>
                    </Grid>

                    <StackPanel Width="420"
                                Margin="0,28,0,0"
                                HorizontalAlignment="Center">
                        <TextBlock Margin="8,0,0,8"
                                   Foreground="#FBF7FF"
                                   Text="Email" />
                        <Border Background="{StaticResource LltInputBrush}"
                                BorderBrush="#D5C3E7"
                                BorderThickness="2"
                                CornerRadius="22">
                            <TextBox Background="Transparent"
                                     BorderThickness="0"
                                     FontSize="15"
                                     Foreground="{StaticResource LltInkBrush}"
                                     Padding="18,14"
                                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />
                        </Border>

                        <StackPanel Margin="0,16,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowFullName}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <TextBlock Margin="8,0,0,8"
                                       Foreground="#FBF7FF"
                                       Text="Полное имя" />
                            <Border Background="{StaticResource LltInputBrush}"
                                    BorderBrush="#D5C3E7"
                                    BorderThickness="2"
                                    CornerRadius="22">
                                <TextBox Background="Transparent"
                                         BorderThickness="0"
                                         FontSize="15"
                                         Foreground="{StaticResource LltInkBrush}"
                                         Padding="18,14"
                                         Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" />
                            </Border>
                        </StackPanel>

                        <TextBlock Margin="8,16,0,8"
                                   Foreground="#FBF7FF"
                                   Text="Пароль" />
                        <Border Background="{StaticResource LltInputBrush}"
                                BorderBrush="#D5C3E7"
                                BorderThickness="2"
                                CornerRadius="22">
                            <PasswordBox Background="Transparent"
                                         BorderThickness="0"
                                         FontSize="15"
                                         Foreground="{StaticResource LltInkBrush}"
                                         Padding="18,14"
                                         PasswordChanged="PasswordBox_OnPasswordChanged" />
                        </Border>

                        <TextBlock Margin="8,16,0,0"
                                   Foreground="#FFF0F0"
                                   Text="{Binding ErrorMessage}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <TextBlock Margin="0,22,0,0"
                               HorizontalAlignment="Center"
                               Foreground="#F5EEFE"
                               Text="Курсы, практика и понятный вход в IT без лишнего шума."
                               TextAlignment="Center"
                               TextWrapping="Wrap" />

                    <Button Width="320"
                            Height="50"
                            Margin="0,20,0,0"
                            HorizontalAlignment="Center"
                            Style="{StaticResource LltLightButtonStyle}"
                            Command="{Binding SubmitCommand}"
                            Content="{Binding ModeActionText}" />

                    <Border Margin="0,14,0,0"
                            Padding="10,6"
                            HorizontalAlignment="Center"
                            Background="#5C3B7B"
                            BorderBrush="#C5A9E0"
                            BorderThickness="1"
                            CornerRadius="16">
                        <Button HorizontalAlignment="Center"
                                Style="{StaticResource LltLinkButtonStyle}"
                                Command="{Binding ToggleModeCommand}"
                                Content="{Binding SwitchModeText}" />
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
