<Page x:Class="OnlineCourses.Desktop.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="LoginPage">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="18">
            <Border MaxWidth="920"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#6E4A94"
                    BorderBrush="#B698D5"
                    BorderThickness="1"
                    CornerRadius="30">
                <StackPanel>
                    <Border HorizontalAlignment="Center"
                            Padding="32,12"
                            Background="#FAF7FD"
                            BorderBrush="#DED0ED"
                            BorderThickness="1"
                            CornerRadius="26">
                        <TextBlock FontSize="24"
                                   Foreground="{StaticResource LltInkBrush}"
                                   Text="{Binding ModeTitle}" />
                    </Border>

                    <WrapPanel Margin="0,24,0,0"
                               HorizontalAlignment="Center"
                               ItemHeight="Auto"
                               ItemWidth="380">
                        <StackPanel Width="380"
                                    Margin="0,0,22,16"
                                    VerticalAlignment="Top">
                            <TextBlock Margin="8,0,0,8"
                                       Foreground="#FBF7FF"
                                       Text="Email" />
                            <TextBox Style="{StaticResource LltTextBoxStyle}"
                                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />

                            <StackPanel Margin="0,16,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowFullName}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <TextBlock Margin="8,0,0,8"
                                           Foreground="#FBF7FF"
                                           Text="Полное имя" />
                                <TextBox Style="{StaticResource LltTextBoxStyle}"
                                         Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <TextBlock Margin="8,16,0,8"
                                       Foreground="#FBF7FF"
                                       Text="Пароль" />
                            <PasswordBox Style="{StaticResource LltPasswordBoxStyle}"
                                         PasswordChanged="PasswordBox_OnPasswordChanged" />

                            <TextBlock Margin="8,16,0,0"
                                       Foreground="#FFF0F0"
                                       Text="{Binding ErrorMessage}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <Border Width="300"
                                MinHeight="340"
                                Margin="0,0,0,16"
                                Padding="16"
                                Background="#190A20"
                                BorderBrush="#B596D1"
                                BorderThickness="1"
                                CornerRadius="24">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock HorizontalAlignment="Center"
                                           Foreground="#E6D6F7"
                                           FontSize="16"
                                           Text="LLT" />

                                <Border Grid.Row="1"
                                        Margin="0,14,0,14"
                                        CornerRadius="22"
                                        ClipToBounds="True">
                                    <Image Source="/Assets/mascot.jpg"
                                           Stretch="UniformToFill" />
                                </Border>

                                <TextBlock Grid.Row="2"
                                           HorizontalAlignment="Center"
                                           Foreground="#E6D6F7"
                                           Text="Low-Level to Top" />
                            </Grid>
                        </Border>
                    </WrapPanel>

                    <TextBlock Margin="0,6,0,0"
                               HorizontalAlignment="Center"
                               Foreground="#F5EEFE"
                               Text="Курсы, практика и понятный вход в IT без лишнего шума."
                               TextAlignment="Center"
                               TextWrapping="Wrap" />

                    <Button Width="320"
                            Height="50"
                            Margin="0,20,0,0"
                            HorizontalAlignment="Center"
                            Style="{StaticResource LltLightButtonStyle}"
                            Command="{Binding SubmitCommand}"
                            Content="{Binding ModeActionText}" />

                    <Border Margin="0,14,0,0"
                            Padding="10,6"
                            HorizontalAlignment="Center"
                            Background="#5C3B7B"
                            BorderBrush="#C5A9E0"
                            BorderThickness="1"
                            CornerRadius="16">
                        <Button HorizontalAlignment="Center"
                                Style="{StaticResource LltLinkButtonStyle}"
                                Command="{Binding ToggleModeCommand}"
                                Content="{Binding SwitchModeText}" />
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
