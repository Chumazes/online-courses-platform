<Page x:Class="OnlineCourses.Desktop.Pages.StudentStoriesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="StudentStoriesPage">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="26">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="28"
                    Background="#6F4B96"
                    BorderBrush="#B494D4"
                    BorderThickness="1"
                    CornerRadius="28">
                <StackPanel>
                    <TextBlock FontSize="34"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource LltLightTextBrush}"
                               Text="Отзывы и истории студентов" />
                    <TextBlock Margin="0,14,0,0"
                               FontSize="18"
                               Foreground="#EFE5F8"
                               Text="Показываем не только программу курсов, но и то, как студенты проходят путь: что им помогает, что запоминается и почему они остаются в платформе."
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <WrapPanel Grid.Row="1"
                       Margin="0,18,0,0">
                <Border Width="250"
                        Margin="0,0,16,16"
                        Padding="18"
                        Background="#7440A7"
                        BorderBrush="#A97AD4"
                        BorderThickness="1"
                        CornerRadius="24">
                    <StackPanel>
                        <TextBlock Foreground="#E7D8F7"
                                   Text="Опубликованные отзывы" />
                        <TextBlock Margin="0,10,0,0"
                                   FontSize="34"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource LltLightTextBrush}"
                                   Text="{Binding StoriesCount}" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="#E7D8F7"
                                   Text="Живые отклики, которые уже видны другим пользователям" />
                    </StackPanel>
                </Border>

                <Border Width="250"
                        Margin="0,0,16,16"
                        Padding="18"
                        Background="#7440A7"
                        BorderBrush="#A97AD4"
                        BorderThickness="1"
                        CornerRadius="24">
                    <StackPanel>
                        <TextBlock Foreground="#E7D8F7"
                                   Text="Курсы с отзывами" />
                        <TextBlock Margin="0,10,0,0"
                                   FontSize="34"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource LltLightTextBrush}"
                                   Text="{Binding ReviewedCoursesCount}" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="#E7D8F7"
                                   Text="Направления, где студенты уже оставили свой фидбек" />
                    </StackPanel>
                </Border>

                <Border Width="250"
                        Margin="0,0,0,16"
                        Padding="18"
                        Background="#7440A7"
                        BorderBrush="#A97AD4"
                        BorderThickness="1"
                        CornerRadius="24">
                    <StackPanel>
                        <TextBlock Foreground="#E7D8F7"
                                   Text="Средняя оценка" />
                        <TextBlock Margin="0,10,0,0"
                                   FontSize="34"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource LltLightTextBrush}"
                                   Text="{Binding AverageRatingCaption}" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="#E7D8F7"
                                   Text="По тем отзывам, которые мы показываем на витрине" />
                    </StackPanel>
                </Border>
            </WrapPanel>

            <Border Grid.Row="2"
                    Margin="0,2,0,0"
                    Padding="22"
                    Background="#F2EDF7"
                    BorderBrush="#D7C8E7"
                    BorderThickness="1"
                    CornerRadius="24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Margin="0,0,14,0"
                            Padding="18"
                            Background="#6F4B96"
                            BorderBrush="#B494D4"
                            BorderThickness="1"
                            CornerRadius="22">
                        <StackPanel>
                            <TextBlock FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource LltLightTextBrush}"
                                       Text="1. Вход без страха" />
                            <TextBlock Margin="0,10,0,0"
                                       Foreground="#EEE5F8"
                                       Text="Студенту не нужно угадывать, с чего начать: есть каталог, уровни, категории и понятный маршрут от первого курса до прогресса по урокам."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Margin="7,0"
                            Padding="18"
                            Background="#6F4B96"
                            BorderBrush="#B494D4"
                            BorderThickness="1"
                            CornerRadius="22">
                        <StackPanel>
                            <TextBlock FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource LltLightTextBrush}"
                                       Text="2. Практика внутри платформы" />
                            <TextBlock Margin="0,10,0,0"
                                       Foreground="#EEE5F8"
                                       Text="Отзывы, прогресс, запись на курс, уроки и профиль уже работают в одном продукте, а не раскиданы по разным экранам без связи."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Margin="14,0,0,0"
                            Padding="18"
                            Background="#6F4B96"
                            BorderBrush="#B494D4"
                            BorderThickness="1"
                            CornerRadius="22">
                        <StackPanel>
                            <TextBlock FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource LltLightTextBrush}"
                                       Text="3. Видимый результат" />
                            <TextBlock Margin="0,10,0,0"
                                       Foreground="#EEE5F8"
                                       Text="Преподаватель видит студентов и аналитику, админ модерирует отзывы, а студент получает понятную обратную связь и видит свой прогресс."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <StackPanel Grid.Row="3"
                        Margin="0,18,0,0">
                <TextBlock Foreground="#9A1C30"
                           Text="{Binding ErrorMessage}"
                           TextWrapping="Wrap" />

                <Border Margin="0,18,0,0"
                        Padding="22"
                        Background="#F2EDF7"
                        BorderBrush="#D7C8E7"
                        BorderThickness="1"
                        CornerRadius="24">
                    <StackPanel>
                        <TextBlock FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource LltInkBrush}"
                                   Text="Что говорят студенты" />

                        <ItemsControl Margin="0,18,0,0"
                                      ItemsSource="{Binding Stories}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,16"
                                            Padding="18"
                                            Background="#6F4B96"
                                            BorderBrush="#B494D4"
                                            BorderThickness="1"
                                            CornerRadius="22">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Grid Width="56"
                                                  Height="56"
                                                  Margin="0,0,16,0">
                                                <Border Background="#2A1238"
                                                        CornerRadius="28" />
                                                <Image Source="{Binding AvatarSource}"
                                                       Stretch="UniformToFill"
                                                       Visibility="{Binding HasAvatar, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <Image.Clip>
                                                        <EllipseGeometry Center="28,28"
                                                                         RadiusX="28"
                                                                         RadiusY="28" />
                                                    </Image.Clip>
                                                </Image>
                                                <TextBlock VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource LltLightTextBrush}"
                                                           Text="{Binding Initials}"
                                                           Visibility="{Binding ShowInitials, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            </Grid>

                                            <StackPanel Grid.Column="1">
                                                <DockPanel LastChildFill="False">
                                                    <StackPanel DockPanel.Dock="Left">
                                                        <TextBlock FontSize="22"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource LltLightTextBrush}"
                                                                   Text="{Binding UserName}" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   Foreground="#E7D8F7"
                                                                   Text="{Binding CourseTitle}" />
                                                    </StackPanel>

                                                    <StackPanel DockPanel.Dock="Right"
                                                                HorizontalAlignment="Right">
                                                        <TextBlock HorizontalAlignment="Right"
                                                                   Foreground="#FFD45E"
                                                                   Text="{Binding RatingText}" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   HorizontalAlignment="Right"
                                                                   Foreground="#E7D8F7"
                                                                   Text="{Binding ReviewDateText}" />
                                                    </StackPanel>
                                                </DockPanel>

                                                <TextBlock Margin="0,14,0,0"
                                                           Foreground="#F4EEFA"
                                                           Text="{Binding SafeComment}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Padding="24"
                                Background="#C5FFFFFF"
                                BorderBrush="#4EFFFFFF"
                                BorderThickness="1"
                                CornerRadius="24"
                                Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="18"
                                       Foreground="{StaticResource LltInkSoftBrush}"
                                       Text="Пока на витрине ещё нет опубликованных отзывов. Их можно будет увидеть сразу после первых модераций."
                                       TextAlignment="Center"
                                       TextWrapping="Wrap" />
                        </Border>

                        <Border Padding="24"
                                Background="#C5FFFFFF"
                                BorderBrush="#4EFFFFFF"
                                BorderThickness="1"
                                CornerRadius="24"
                                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="18"
                                       Foreground="{StaticResource LltInkSoftBrush}"
                                       Text="Загружаем истории и отзывы студентов..."
                                       TextAlignment="Center"
                                       TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
