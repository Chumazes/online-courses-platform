<Page x:Class="OnlineCourses.Desktop.Pages.RoleDashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="RoleDashboardPage">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="26">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="26"
                    Background="#6F4B96"
                    BorderBrush="#B494D4"
                    BorderThickness="1"
                    CornerRadius="28">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock FontSize="34"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource LltLightTextBrush}"
                                   Text="{Binding Title}" />
                        <TextBlock Margin="0,12,0,0"
                                   Foreground="#EFE5F8"
                                   Text="{Binding Subtitle}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Width="220"
                            VerticalAlignment="Center"
                            Style="{StaticResource LltAccentButtonStyle}"
                            Click="OpenManageCoursesButton_OnClick"
                            Content="Открыть управление" />
                </Grid>
            </Border>

            <TextBlock Grid.Row="1"
                       Margin="6,12,0,0"
                       Foreground="#9A1C30"
                       Text="{Binding ErrorMessage}"
                       TextWrapping="Wrap" />

            <WrapPanel Grid.Row="2"
                       Margin="0,18,0,18">
                <Border Width="250"
                        Margin="0,0,16,16"
                        Padding="18"
                        Background="#7440A7"
                        BorderBrush="#A97AD4"
                        BorderThickness="1"
                        CornerRadius="24">
                    <StackPanel>
                        <TextBlock Foreground="#E7D8F7"
                                   Text="Курсы" />
                        <TextBlock Margin="0,10,0,0"
                                   FontSize="34"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource LltLightTextBrush}"
                                   Text="{Binding TotalCourses}" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="#E7D8F7"
                                   Text="Всего в этой панели" />
                    </StackPanel>
                </Border>

                <Border Width="250"
                        Margin="0,0,16,16"
                        Padding="18"
                        Background="#7440A7"
                        BorderBrush="#A97AD4"
                        BorderThickness="1"
                        CornerRadius="24">
                    <StackPanel>
                        <TextBlock Foreground="#E7D8F7"
                                   Text="Опубликовано" />
                        <TextBlock Margin="0,10,0,0"
                                   FontSize="34"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource LltLightTextBrush}"
                                   Text="{Binding PublishedCourses}" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="#E7D8F7"
                                   Text="{Binding DraftCourses, StringFormat=Черновиков: {0}}" />
                    </StackPanel>
                </Border>

                <Border Width="250"
                        Margin="0,0,16,16"
                        Padding="18"
                        Background="#7440A7"
                        BorderBrush="#A97AD4"
                        BorderThickness="1"
                        CornerRadius="24">
                    <StackPanel>
                        <TextBlock Foreground="#E7D8F7"
                                   Text="Студенты" />
                        <TextBlock Margin="0,10,0,0"
                                   FontSize="34"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource LltLightTextBrush}"
                                   Text="{Binding TotalStudents}" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="#E7D8F7"
                                   Text="Во всех курсах" />
                    </StackPanel>
                </Border>

                <Border Width="250"
                        Margin="0,0,0,16"
                        Padding="18"
                        Background="#7440A7"
                        BorderBrush="#A97AD4"
                        BorderThickness="1"
                        CornerRadius="24">
                    <StackPanel>
                        <TextBlock Foreground="#E7D8F7"
                                   Text="Средний рейтинг" />
                        <TextBlock Margin="0,10,0,0"
                                   FontSize="34"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource LltLightTextBrush}"
                                   Text="{Binding AverageRatingCaption}" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="#E7D8F7"
                                   Text="По курсам с оценками" />
                    </StackPanel>
                </Border>
            </WrapPanel>

            <Border Grid.Row="3"
                    Padding="22"
                    Background="#F2EDF7"
                    BorderBrush="#D7C8E7"
                    BorderThickness="1"
                    CornerRadius="24">
                <StackPanel>
                    <TextBlock FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource LltInkBrush}"
                               Text="Курсы в работе" />

                    <ListBox Margin="0,18,0,0"
                             ItemsSource="{Binding Courses}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="18"
                                        Margin="0,0,0,14"
                                        Background="#6F4B96"
                                        BorderBrush="#B494D4"
                                        BorderThickness="1"
                                        CornerRadius="22">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock FontSize="22"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource LltLightTextBrush}"
                                                       Text="{Binding Title}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,10,0,0"
                                                       Foreground="#EEE5F8"
                                                       Text="{Binding Description}"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxHeight="64" />
                                            <Border Margin="0,14,0,0"
                                                    Padding="12"
                                                    Background="#220A2C"
                                                    CornerRadius="18">
                                                <TextBlock Foreground="#E7D8F7"
                                                           Text="{Binding MetaCaption}"
                                                           TextWrapping="Wrap" />
                                            </Border>
                                        </StackPanel>

                                        <Border Grid.Column="1"
                                                Margin="18,0,0,0"
                                                Padding="10,4"
                                                VerticalAlignment="Top"
                                                Background="#F4EEFA"
                                                CornerRadius="14">
                                            <TextBlock Foreground="{StaticResource LltInkBrush}"
                                                       Text="{Binding StatusText}" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Padding="28"
                            Background="#C5FFFFFF"
                            BorderBrush="#4EFFFFFF"
                            BorderThickness="1"
                            CornerRadius="24"
                            Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="18"
                                   Foreground="{StaticResource LltInkSoftBrush}"
                                   Text="Курсы пока не найдены."
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />
                    </Border>

                    <Border Padding="28"
                            Background="#C5FFFFFF"
                            BorderBrush="#4EFFFFFF"
                            BorderThickness="1"
                            CornerRadius="24"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="18"
                                   Foreground="{StaticResource LltInkSoftBrush}"
                                   Text="Загружаем панель преподавателя..."
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
