<Page x:Class="OnlineCourses.Desktop.Pages.CoursesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="CoursesPage">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   FontSize="26"
                   FontWeight="SemiBold"
                   Text="Доступные курсы" />

        <Grid Grid.Row="1"
              Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox Height="38"
                     Padding="12,8"
                     VerticalContentAlignment="Center"
                     Background="White"
                     BorderBrush="#D1D5DB"
                     BorderThickness="1"
                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" />

            <Button Grid.Column="1"
                    Width="120"
                    Height="38"
                    Margin="12,0,0,0"
                    Background="#E5E7EB"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1"
                    Command="{Binding ClearSearchCommand}"
                    Content="Очистить" />
        </Grid>

        <TextBlock Grid.Row="2"
                   Margin="0,10,0,0"
                   Foreground="Red"
                   Text="{Binding ErrorMessage}"
                   TextWrapping="Wrap" />

        <Grid Grid.Row="3"
              Margin="0,14,0,14">
            <ListBox ItemsSource="{Binding Courses}"
                     SelectedItem="{Binding SelectedCourse}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="14"
                                Margin="0,0,0,10"
                                Background="White"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                CornerRadius="10">
                            <StackPanel>
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Text="{Binding Title}" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="#374151"
                                           Text="{Binding Description}"
                                           TextWrapping="Wrap" />
                                <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                                    <TextBlock Foreground="#6B7280" Text="{Binding Level}" />
                                    <TextBlock Margin="12,0,0,0"
                                               Foreground="#111827"
                                               Text="{Binding Price, StringFormat={}{0} ₽}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border Padding="24"
                    Background="#F9FAFB"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="12"
                    Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="16"
                           Foreground="#4B5563"
                           Text="{Binding EmptyStateMessage}"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
            </Border>

            <Border Padding="24"
                    Background="#F9FAFB"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="12"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="16"
                           Foreground="#4B5563"
                           Text="Загружаем курсы..."
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
            </Border>
        </Grid>

        <Button Grid.Row="4"
                Width="170"
                Height="38"
                HorizontalAlignment="Right"
                Background="#111827"
                Foreground="White"
                Command="{Binding OpenCourseCommand}"
                Content="Открыть курс" />
    </Grid>
</Page>
