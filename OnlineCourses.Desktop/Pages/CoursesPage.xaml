<Page x:Class="OnlineCourses.Desktop.Pages.CoursesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="CoursesPage">
    <Grid Margin="26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="24"
                Background="#6F4B96"
                BorderBrush="#B494D4"
                BorderThickness="1"
                CornerRadius="28">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock FontSize="34"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource LltLightTextBrush}"
                               Text="Каталог курсов" />
                    <TextBlock Margin="0,10,0,0"
                               Foreground="#EDE2F8"
                               Text="Выбирай направление, смотри программу и собирай свой маршрут от low-level к top."
                               TextWrapping="Wrap" />
                </StackPanel>

                <Button Grid.Column="1"
                        Width="170"
                        VerticalAlignment="Center"
                        Style="{StaticResource LltLightButtonStyle}"
                        Click="MyCoursesButton_OnClick"
                        Content="Мои курсы" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,18,0,0"
                Padding="18"
                Background="#F1ECF6"
                BorderBrush="#D3C1E3"
                BorderThickness="1"
                CornerRadius="22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Width="62"
                        Height="62"
                        Margin="0,0,14,0"
                        CornerRadius="18"
                        ClipToBounds="True">
                    <Image Source="/Assets/mascot.jpg" Stretch="UniformToFill" />
                </Border>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center">
                    <TextBlock Margin="8,0,0,8"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource LltInkBrush}"
                               Text="Поиск по каталогу" />
                    <TextBox Height="48"
                             Style="{StaticResource LltTextBoxStyle}"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Введите название курса" />
                </StackPanel>

                <Button Grid.Column="2"
                        Width="120"
                        Margin="14,28,0,0"
                        VerticalAlignment="Top"
                        Style="{StaticResource LltPrimaryButtonStyle}"
                        Command="{Binding ClearSearchCommand}"
                        Content="Очистить" />
            </Grid>
        </Border>

        <TextBlock Grid.Row="2"
                   Margin="6,12,0,0"
                   Foreground="#9A1C30"
                   Text="{Binding ErrorMessage}"
                   TextWrapping="Wrap" />

        <Grid Grid.Row="3"
              Margin="0,18,0,18">
            <ListBox x:Name="CoursesList"
                     ItemsSource="{Binding Courses}"
                     MouseDoubleClick="CoursesList_OnMouseDoubleClick"
                     SelectedItem="{Binding SelectedCourse}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="20"
                                Margin="0,0,0,14"
                                Background="#6F4B96"
                                BorderBrush="#B494D4"
                                BorderThickness="1"
                                CornerRadius="24">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock FontSize="24"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource LltLightTextBrush}"
                                               Text="{Binding Title}" />
                                    <TextBlock Margin="0,12,0,0"
                                               Foreground="#F0E8F8"
                                               Text="{Binding Description}"
                                               TextWrapping="Wrap" />

                                    <WrapPanel Margin="0,16,0,0">
                                        <Border Padding="10,4"
                                                Margin="0,0,10,0"
                                                Background="#FCFAFE"
                                                CornerRadius="16">
                                            <TextBlock Foreground="{StaticResource LltInkBrush}"
                                                       Text="{Binding Level}" />
                                        </Border>
                                        <Border Padding="10,4"
                                                Background="#63E62E"
                                                CornerRadius="16">
                                            <TextBlock Foreground="{StaticResource LltAccentDarkBrush}"
                                                       Text="{Binding Price, StringFormat=от {0} ₽}" />
                                        </Border>
                                    </WrapPanel>
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Width="120"
                                        Height="120"
                                        Margin="20,0,0,0"
                                        Background="#26112F"
                                        BorderBrush="#A88AC8"
                                        BorderThickness="1"
                                        CornerRadius="20"
                                        VerticalAlignment="Center">
                                    <Grid>
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="38"
                                                   FontWeight="SemiBold"
                                                   Foreground="#EBDDFA"
                                                   Text="LLT" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border Padding="28"
                    Background="#F3EEF8"
                    BorderBrush="#D8C9E8"
                    BorderThickness="1"
                    CornerRadius="24"
                    Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="18"
                           Foreground="{StaticResource LltInkSoftBrush}"
                           Text="{Binding EmptyStateMessage}"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
            </Border>

            <Border Padding="28"
                    Background="#F3EEF8"
                    BorderBrush="#D8C9E8"
                    BorderThickness="1"
                    CornerRadius="24"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="18"
                           Foreground="{StaticResource LltInkSoftBrush}"
                           Text="Загружаем курсы..."
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
            </Border>
        </Grid>

        <Button Grid.Row="4"
                Width="220"
                HorizontalAlignment="Right"
                Style="{StaticResource LltAccentButtonStyle}"
                Command="{Binding OpenCourseCommand}"
                Content="Открыть курс" />
    </Grid>
</Page>
