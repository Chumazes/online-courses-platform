<Page x:Class="OnlineCourses.Desktop.Pages.LessonDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="LessonDetailsPage">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="26">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="26"
                    Background="#7A43AE"
                    BorderBrush="#A97AD4"
                    BorderThickness="1"
                    CornerRadius="30">
                <StackPanel>
                    <TextBlock Foreground="#EBDDFA"
                               Text="{Binding SectionTitle, StringFormat=Раздел: {0}}" />

                    <TextBlock Margin="0,14,0,0"
                               FontSize="34"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource LltLightTextBrush}"
                               Text="{Binding Title}"
                               TextWrapping="Wrap" />

                    <WrapPanel Margin="0,18,0,0">
                        <Border Padding="12,5"
                                Margin="0,0,10,10"
                                Background="#F4EEFA"
                                CornerRadius="16">
                            <TextBlock Foreground="{StaticResource LltInkBrush}"
                                       Text="{Binding MetaText}" />
                        </Border>

                        <Border Padding="12,5"
                                Margin="0,0,10,10"
                                Background="#220A2C"
                                BorderBrush="#9C71C8"
                                BorderThickness="1"
                                CornerRadius="16">
                            <TextBlock Foreground="#EBDDFA"
                                       Text="{Binding AccessText}" />
                        </Border>
                    </WrapPanel>

                    <Border Margin="0,20,0,0"
                            Padding="18"
                            Background="#200A2B"
                            BorderBrush="#9C71C8"
                            BorderThickness="1"
                            CornerRadius="20">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="{StaticResource LltLightTextBrush}"
                                       Text="{Binding CompletionStateText}" />

                            <Button Width="250"
                                    Margin="0,16,0,0"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource LltAccentButtonStyle}"
                                    Command="{Binding CompleteCommand}"
                                    Content="{Binding CompleteButtonText}" />

                            <TextBlock Margin="0,12,0,0"
                                       Foreground="#EAFFD8"
                                       Text="{Binding ProgressStatusMessage}"
                                       TextWrapping="Wrap" />

                            <TextBlock Margin="0,8,0,0"
                                       Foreground="#FFE2E2"
                                       Text="{Binding ProgressErrorMessage}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,18,0,0"
                    Padding="20"
                    Background="#C5FFFFFF"
                    BorderBrush="#4EFFFFFF"
                    BorderThickness="1"
                    CornerRadius="24"
                    Visibility="{Binding HasAttachment, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Text="Файл урока" />

                    <TextBlock Margin="0,12,0,0"
                               FontWeight="SemiBold"
                               Text="{Binding AttachmentName}" />

                    <TextBlock Margin="0,8,0,0"
                               Foreground="{StaticResource LltInkSoftBrush}"
                               Text="{Binding AttachmentSizeText}" />

                    <Button Width="180"
                            Margin="0,14,0,0"
                            HorizontalAlignment="Left"
                            Style="{StaticResource LltPrimaryButtonStyle}"
                            Click="OpenAttachmentButton_OnClick"
                            Content="Открыть файл" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Margin="0,18,0,0"
                    Padding="24"
                    Background="#C5FFFFFF"
                    BorderBrush="#4EFFFFFF"
                    BorderThickness="1"
                    CornerRadius="28">
                <StackPanel>
                    <TextBlock FontSize="28"
                               FontWeight="SemiBold"
                               Text="Содержимое урока" />

                    <Border Margin="0,16,0,0"
                            Padding="20"
                            Background="#7340A6"
                            BorderBrush="#A97AD4"
                            BorderThickness="1"
                            CornerRadius="24">
                        <TextBlock Foreground="{StaticResource LltLightTextBrush}"
                                   FontSize="15"
                                   LineHeight="24"
                                   Text="{Binding Content}"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
