<Page x:Class="OnlineCourses.Desktop.Pages.ManageCourseReviewsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="ManageCourseReviewsPage">
    <Grid Margin="26">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.05*" />
            <ColumnDefinition Width="1.15*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0"
              Margin="0,0,18,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="22"
                    Background="#7A43AE"
                    BorderBrush="#A97AD4"
                    BorderThickness="1"
                    CornerRadius="28">
                <StackPanel>
                    <TextBlock FontSize="30"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource LltLightTextBrush}"
                               Text="Отзывы курса" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#E7D8F7"
                               Text="{Binding Course.Title}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#E7D8F7"
                               Text="{Binding RatingSummaryText}" />
                </StackPanel>
            </Border>

            <TextBlock Grid.Row="1"
                       Margin="6,12,0,0"
                       Foreground="#9A1C30"
                       Text="{Binding ErrorMessage}"
                       TextWrapping="Wrap" />

            <Grid Grid.Row="2"
                  Margin="0,18,0,0">
                <ListBox ItemsSource="{Binding Reviews}"
                         SelectedItem="{Binding SelectedReview}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="18"
                                    Margin="0,0,0,14"
                                    Background="#7440A7"
                                    BorderBrush="#A97AD4"
                                    BorderThickness="1"
                                    CornerRadius="24">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Grid Width="48"
                                          Height="48"
                                          Margin="0,0,14,0">
                                        <Border Background="#6F4B96"
                                                CornerRadius="24" />
                                        <Image Source="{Binding AvatarSource}"
                                               Stretch="UniformToFill"
                                               Visibility="{Binding HasAvatar, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <Image.Clip>
                                                <EllipseGeometry Center="24,24"
                                                                 RadiusX="24"
                                                                 RadiusY="24" />
                                            </Image.Clip>
                                        </Image>
                                        <TextBlock VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource LltLightTextBrush}"
                                                   Text="{Binding Initials}"
                                                   Visibility="{Binding ShowInitials, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    </Grid>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock FontSize="20"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource LltLightTextBrush}"
                                                   Text="{Binding UserName}" />
                                        <TextBlock Margin="0,10,0,0"
                                                   Foreground="#EEE5F8"
                                                   Text="{Binding RatingText}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Foreground="#EEE5F8"
                                                   Text="{Binding CommentText}"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <Border Grid.Column="2"
                                            Padding="10,4"
                                            Background="#F4EEFA"
                                            CornerRadius="14"
                                            VerticalAlignment="Top">
                                        <TextBlock Foreground="{StaticResource LltInkBrush}"
                                                   Text="{Binding ApprovalStateText}" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Padding="28"
                        Background="#C5FFFFFF"
                        BorderBrush="#4EFFFFFF"
                        BorderThickness="1"
                        CornerRadius="24"
                        Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="18"
                               Foreground="{StaticResource LltInkSoftBrush}"
                               Text="У этого курса пока нет отзывов."
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </Border>

                <Border Padding="28"
                        Background="#C5FFFFFF"
                        BorderBrush="#4EFFFFFF"
                        BorderThickness="1"
                        CornerRadius="24"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="18"
                               Foreground="{StaticResource LltInkSoftBrush}"
                               Text="Загружаем отзывы..."
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Column="1"
                Padding="24"
                Background="#7A43AE"
                BorderBrush="#A97AD4"
                BorderThickness="1"
                CornerRadius="28">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource LltLightTextBrush}"
                               Text="Карточка отзыва" />

                    <TextBlock Margin="0,12,0,0"
                               Foreground="#EAFFD8"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap" />

                    <TextBlock Margin="0,8,0,0"
                               Foreground="#FFE2E2"
                               Text="{Binding ErrorMessage}"
                               TextWrapping="Wrap" />

                    <Border Margin="0,20,0,0"
                            Padding="18"
                            Background="#200A2B"
                            BorderBrush="#9C71C8"
                            BorderThickness="1"
                            CornerRadius="22">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Grid Width="56"
                                      Height="56"
                                      Margin="0,0,14,0">
                                    <Border Background="#6F4B96"
                                            CornerRadius="28" />
                                    <Image Source="{Binding SelectedReview.AvatarSource}"
                                           Stretch="UniformToFill"
                                           Visibility="{Binding SelectedReview.HasAvatar, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Image.Clip>
                                            <EllipseGeometry Center="28,28"
                                                             RadiusX="28"
                                                             RadiusY="28" />
                                        </Image.Clip>
                                    </Image>
                                    <TextBlock VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource LltLightTextBrush}"
                                               Text="{Binding SelectedReview.Initials}"
                                               Visibility="{Binding SelectedReview.ShowInitials, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </Grid>

                                <TextBlock Grid.Column="1"
                                           VerticalAlignment="Center"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource LltLightTextBrush}"
                                           Text="{Binding SelectedReview.UserName}" />
                            </Grid>

                            <WrapPanel Margin="0,14,0,0">
                                <Border Padding="10,4"
                                        Margin="0,0,10,10"
                                        Background="#F4EEFA"
                                        CornerRadius="14">
                                    <TextBlock Foreground="{StaticResource LltInkBrush}"
                                               Text="{Binding SelectedReview.RatingValueText}" />
                                </Border>
                                <Border Padding="10,4"
                                        Margin="0,0,10,10"
                                        Background="#F4EEFA"
                                        CornerRadius="14">
                                    <TextBlock Foreground="{StaticResource LltInkBrush}"
                                               Text="{Binding SelectedReview.ApprovalStateText}" />
                                </Border>
                                <Border Padding="10,4"
                                        Background="#F4EEFA"
                                        CornerRadius="14">
                                    <TextBlock Foreground="{StaticResource LltInkBrush}"
                                               Text="{Binding SelectedReview.ReviewDateText}" />
                                </Border>
                            </WrapPanel>

                            <TextBlock Margin="0,14,0,0"
                                       Foreground="#F0E8F8"
                                       Text="{Binding SelectedReview.RatingText}" />

                            <TextBlock Margin="0,14,0,0"
                                       Foreground="#F0E8F8"
                                       Text="{Binding SelectedReview.CommentText}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <StackPanel Margin="0,22,0,0"
                                Visibility="{Binding CanModerate, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Foreground="{StaticResource LltLightTextBrush}"
                                   Text="Действия администратора" />

                        <WrapPanel Margin="0,12,0,0">
                            <Button Width="170"
                                    Margin="0,0,10,10"
                                    Style="{StaticResource LltAccentButtonStyle}"
                                    Click="ApproveReviewButton_OnClick"
                                    Content="Опубликовать"
                                    IsEnabled="{Binding HasSelectedReview}" />
                            <Button Width="170"
                                    Margin="0,0,10,10"
                                    Style="{StaticResource LltLightButtonStyle}"
                                    Click="RejectReviewButton_OnClick"
                                    Content="На доработку"
                                    IsEnabled="{Binding HasSelectedReview}" />
                            <Button Width="170"
                                    Margin="0,0,10,10"
                                    Style="{StaticResource LltDangerButtonStyle}"
                                    Click="DeleteReviewButton_OnClick"
                                    Content="Удалить отзыв"
                                    IsEnabled="{Binding HasSelectedReview}" />
                        </WrapPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
