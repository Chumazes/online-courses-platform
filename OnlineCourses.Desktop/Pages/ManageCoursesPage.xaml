<Page x:Class="OnlineCourses.Desktop.Pages.ManageCoursesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="ManageCoursesPage">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.1*" />
            <ColumnDefinition Width="1.3*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0"
              Margin="0,0,18,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0"
                       LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           FontSize="26"
                           FontWeight="SemiBold"
                           Text="Управление курсами" />
                <Button DockPanel.Dock="Right"
                        Width="150"
                        Height="38"
                        Background="#111827"
                        Foreground="White"
                        Click="CreateCourseButton_OnClick"
                        Content="Новый курс" />
            </DockPanel>

            <TextBlock Grid.Row="1"
                       Margin="0,12,0,0"
                       Foreground="#B91C1C"
                       Text="{Binding ErrorMessage}"
                       TextWrapping="Wrap" />

            <Grid Grid.Row="2"
                  Margin="0,16,0,0">
                <ListBox x:Name="CoursesList"
                         ItemsSource="{Binding Courses}"
                         SelectedItem="{Binding SelectedCourse}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="14"
                                    Margin="0,0,0,10"
                                    Background="White"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <StackPanel>
                                    <DockPanel LastChildFill="False">
                                        <TextBlock DockPanel.Dock="Left"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Title}" />
                                        <Border DockPanel.Dock="Right"
                                                Padding="8,3"
                                                Background="#EFF6FF"
                                                CornerRadius="12">
                                            <TextBlock Foreground="#1D4ED8"
                                                       Text="{Binding StatusText}" />
                                        </Border>
                                    </DockPanel>

                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="#374151"
                                               Text="{Binding Description}"
                                               TextTrimming="CharacterEllipsis" />

                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="#6B7280"
                                               Text="{Binding MetaText}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Padding="24"
                        Background="#F9FAFB"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="12"
                        Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="16"
                               Foreground="#4B5563"
                               Text="У вас пока нет авторских курсов."
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </Border>

                <Border Padding="24"
                        Background="#F9FAFB"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="12"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="16"
                               Foreground="#4B5563"
                               Text="Загружаем ваши курсы..."
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Column="1"
                Padding="22"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Text="{Binding EditorTitle}" />

                    <TextBlock Margin="0,14,0,0"
                               Foreground="#047857"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap" />

                    <TextBlock Margin="0,8,0,0"
                               Foreground="#B91C1C"
                               Text="{Binding ErrorMessage}"
                               TextWrapping="Wrap" />

                    <TextBlock Margin="0,20,0,0"
                               FontWeight="SemiBold"
                               Text="Название" />
                    <TextBox Margin="0,8,0,0"
                             Padding="12,8"
                             Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,18,0,0"
                               FontWeight="SemiBold"
                               Text="Описание" />
                    <TextBox MinHeight="120"
                             Margin="0,8,0,0"
                             Padding="12"
                             AcceptsReturn="True"
                             Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />

                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Margin="0,0,10,0">
                            <TextBlock FontWeight="SemiBold"
                                       Text="Уровень" />
                            <ComboBox Margin="0,8,0,0"
                                      ItemsSource="{Binding Levels}"
                                      SelectedItem="{Binding Level}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Margin="10,0,0,0">
                            <TextBlock FontWeight="SemiBold"
                                       Text="Цена" />
                            <TextBox Margin="0,8,0,0"
                                     Padding="12,8"
                                     Text="{Binding Price, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Margin="0,18,0,0"
                               FontWeight="SemiBold"
                               Text="Статус" />
                    <ComboBox Margin="0,8,0,0"
                              ItemsSource="{Binding Statuses}"
                              SelectedItem="{Binding Status}" />

                    <TextBlock Margin="0,18,0,0"
                               FontWeight="SemiBold"
                               Text="Cover Image URL" />
                    <TextBox Margin="0,8,0,0"
                             Padding="12,8"
                             Text="{Binding CoverImageUrl, UpdateSourceTrigger=PropertyChanged}" />

                    <DockPanel Margin="0,24,0,0"
                               LastChildFill="False">
                        <Button DockPanel.Dock="Left"
                                Width="170"
                                Height="40"
                                Background="#111827"
                                Foreground="White"
                                Command="{Binding SaveCommand}"
                                Content="{Binding SaveButtonText}" />
                        <Button DockPanel.Dock="Right"
                                Width="150"
                                Height="40"
                                Background="#FEE2E2"
                                BorderBrush="#FCA5A5"
                                Foreground="#B91C1C"
                                Click="DeleteCourseButton_OnClick"
                                Content="Удалить курс" />
                    </DockPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
