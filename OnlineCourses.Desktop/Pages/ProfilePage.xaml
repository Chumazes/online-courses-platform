<Page x:Class="OnlineCourses.Desktop.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="ProfilePage">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Border Padding="24"
                    Background="White"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="12">
                <StackPanel>
                    <TextBlock FontSize="28"
                               FontWeight="SemiBold"
                               Text="Профиль" />

                    <StackPanel Margin="0,24,0,0"
                                Orientation="Horizontal">
                        <Border Width="78"
                                Height="78"
                                Background="#2563EB"
                                CornerRadius="39">
                            <Grid ClipToBounds="True">
                                <Image Source="{Binding AvatarDisplayUrl}"
                                       Stretch="UniformToFill"
                                       Visibility="{Binding HasAvatar, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <TextBlock VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           FontSize="24"
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           Text="{Binding Initials}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasAvatar}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <StackPanel Margin="18,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock FontSize="22"
                                       FontWeight="SemiBold"
                                       Text="{Binding FullName}" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="#6B7280"
                                       Text="{Binding Role}" />
                            <Button Width="170"
                                    Height="34"
                                    Margin="0,12,0,0"
                                    HorizontalAlignment="Left"
                                    Background="#2563EB"
                                    Foreground="White"
                                    Click="UploadAvatarButton_OnClick"
                                    Content="Загрузить аватар" />
                        </StackPanel>
                    </StackPanel>

                    <Grid Margin="0,28,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   FontWeight="SemiBold"
                                   Foreground="#374151"
                                   Text="Email" />
                        <TextBlock Grid.Column="1"
                                   Foreground="#111827"
                                   Text="{Binding Email}"
                                   TextWrapping="Wrap" />
                    </Grid>

                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   FontWeight="SemiBold"
                                   Foreground="#374151"
                                   Text="О пользователе" />
                        <TextBox Grid.Column="1"
                                 MinHeight="120"
                                 Padding="16"
                                 Background="#F9FAFB"
                                 BorderBrush="#E5E7EB"
                                 BorderThickness="1"
                                 AcceptsReturn="True"
                                 Text="{Binding Bio, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" />
                    </Grid>

                    <TextBlock Margin="0,18,0,0"
                               Foreground="#047857"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap" />

                    <TextBlock Margin="0,8,0,0"
                               Foreground="#B91C1C"
                               Text="{Binding ErrorMessage}"
                               TextWrapping="Wrap" />

                    <Button Width="170"
                            Height="40"
                            Margin="0,18,0,0"
                            HorizontalAlignment="Left"
                            Background="#111827"
                            Foreground="White"
                            Command="{Binding SaveCommand}"
                            Content="Сохранить bio" />

                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
