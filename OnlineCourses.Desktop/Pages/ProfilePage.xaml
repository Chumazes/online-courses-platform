<Page x:Class="OnlineCourses.Desktop.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="ProfilePage">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="26">
            <Border Padding="26"
                    Background="#C5FFFFFF"
                    BorderBrush="#4EFFFFFF"
                    BorderThickness="1"
                    CornerRadius="28">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Border Width="110"
                                    Height="110"
                                    HorizontalAlignment="Center"
                                    Background="#7641AA"
                                    BorderBrush="#A97AD4"
                                    BorderThickness="1"
                                    CornerRadius="55">
                                <Grid ClipToBounds="True">
                                    <Image Source="{Binding AvatarImageSource}"
                                           Stretch="UniformToFill"
                                           Visibility="{Binding HasAvatar, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <TextBlock VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               FontSize="30"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource LltLightTextBrush}"
                                               Text="{Binding Initials}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasAvatar}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>

                            <Border Margin="0,18,0,0"
                                    Padding="20,10"
                                    HorizontalAlignment="Center"
                                    Background="#7A43AE"
                                    BorderBrush="#A97AD4"
                                    BorderThickness="1"
                                    CornerRadius="22">
                                <TextBlock FontSize="28"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource LltLightTextBrush}"
                                           Text="{Binding FullName}"
                                           TextAlignment="Center" />
                            </Border>

                            <Border Margin="0,10,0,0"
                                    Padding="18,8"
                                    HorizontalAlignment="Center"
                                    Background="#7A43AE"
                                    BorderBrush="#A97AD4"
                                    BorderThickness="1"
                                    CornerRadius="18">
                                <TextBlock Foreground="{StaticResource LltLightTextBrush}"
                                           Text="{Binding Role}" />
                            </Border>

                            <Button Width="220"
                                    Margin="0,18,0,0"
                                    HorizontalAlignment="Center"
                                    Click="UploadAvatarButton_OnClick"
                                    Content="Загрузить аватар">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource LltPrimaryButtonStyle}">
                                        <Setter Property="IsEnabled" Value="True" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSaving}" Value="True">
                                                <Setter Property="IsEnabled" Value="False" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Width="260"
                                    Margin="0,12,0,0"
                                    HorizontalAlignment="Center"
                                    Click="OpenDashboardButton_OnClick"
                                    Content="{Binding DashboardButtonText}"
                                    Visibility="{Binding CanOpenDashboard, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource LltLightButtonStyle}">
                                        <Setter Property="IsEnabled" Value="True" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSaving}" Value="True">
                                                <Setter Property="IsEnabled" Value="False" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>

                        <Border Grid.Column="2"
                                Padding="22"
                                Background="#7540A8"
                                BorderBrush="#A97AD4"
                                BorderThickness="1"
                                CornerRadius="26">
                            <StackPanel>
                                <TextBlock FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource LltLightTextBrush}"
                                           Text="Карточка профиля" />

                                <Border Margin="0,18,0,0"
                                        Padding="18"
                                        Background="#2A1135"
                                        CornerRadius="20">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Foreground="{StaticResource LltLightTextBrush}"
                                                   FontSize="16"
                                                   Text="Email" />
                                        <TextBlock Grid.Column="1"
                                                   Foreground="{StaticResource LltLightTextBrush}"
                                                   FontSize="16"
                                                   Text="{Binding Email}"
                                                   TextWrapping="Wrap" />

                                        <TextBlock Grid.Row="1"
                                                   Margin="0,16,0,0"
                                                   Foreground="{StaticResource LltLightTextBrush}"
                                                   FontSize="16"
                                                   Text="Роль" />
                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="1"
                                                   Margin="0,16,0,0"
                                                   Foreground="{StaticResource LltLightTextBrush}"
                                                   FontSize="16"
                                                   Text="{Binding Role}" />
                                    </Grid>
                                </Border>

                                <TextBlock Margin="0,22,0,10"
                                           FontSize="18"
                                           Foreground="{StaticResource LltLightTextBrush}"
                                           Text="О пользователе" />

                                <TextBox MinHeight="180"
                                         AcceptsReturn="True"
                                         Text="{Binding Bio, UpdateSourceTrigger=PropertyChanged}"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox" BasedOn="{StaticResource LltTextBoxStyle}">
                                            <Setter Property="IsEnabled" Value="True" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSaving}" Value="True">
                                                    <Setter Property="IsEnabled" Value="False" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <TextBlock Margin="0,18,0,0"
                               Foreground="#2E6D21"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap" />

                    <TextBlock Margin="0,10,0,0"
                               Foreground="#9A1C30"
                               Text="{Binding ErrorMessage}"
                               TextWrapping="Wrap" />

                    <Button Width="220"
                            Margin="0,18,0,0"
                            HorizontalAlignment="Left"
                            Style="{StaticResource LltAccentButtonStyle}"
                            Command="{Binding SaveCommand}"
                            Content="{Binding SaveButtonText}" />
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
