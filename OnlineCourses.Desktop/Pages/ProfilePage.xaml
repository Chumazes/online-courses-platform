<Page x:Class="OnlineCourses.Desktop.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="ProfilePage">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Border Padding="24"
                    Background="White"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="12">
                <StackPanel>
                    <TextBlock FontSize="28"
                               FontWeight="SemiBold"
                               Text="Профиль" />

                    <StackPanel Margin="0,24,0,0"
                                Orientation="Horizontal">
                        <Border Width="78"
                                Height="78"
                                Background="#2563EB"
                                CornerRadius="39">
                            <TextBlock VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Text="{Binding Initials}" />
                        </Border>

                        <StackPanel Margin="18,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock FontSize="22"
                                       FontWeight="SemiBold"
                                       Text="{Binding FullName}" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="#6B7280"
                                       Text="{Binding Role}" />
                        </StackPanel>
                    </StackPanel>

                    <Grid Margin="0,28,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   FontWeight="SemiBold"
                                   Foreground="#374151"
                                   Text="Email" />
                        <TextBlock Grid.Column="1"
                                   Foreground="#111827"
                                   Text="{Binding Email}"
                                   TextWrapping="Wrap" />
                    </Grid>

                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   FontWeight="SemiBold"
                                   Foreground="#374151"
                                   Text="О пользователе" />
                        <Border Grid.Column="1"
                                Padding="16"
                                Background="#F9FAFB"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                CornerRadius="10">
                            <TextBlock Foreground="#374151"
                                       LineHeight="24"
                                       Text="{Binding Bio}"
                                       TextWrapping="Wrap" />
                        </Border>
                    </Grid>

                    <TextBlock Margin="0,24,0,0"
                               Foreground="#6B7280"
                               Text="Редактирование профиля и аватар добавим следующим небольшим шагом."
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
