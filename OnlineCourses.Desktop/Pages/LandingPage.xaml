<Page x:Class="OnlineCourses.Desktop.Pages.LandingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="LandingPage">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="26">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="28"
                    Background="#6F4B96"
                    BorderBrush="#B494D4"
                    BorderThickness="1"
                    CornerRadius="28">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Margin="0,0,24,0">
                        <TextBlock FontSize="40"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource LltLightTextBrush}"
                                   Text="Старт в IT без лишнего шума" />
                        <TextBlock Margin="0,14,0,0"
                                   FontSize="18"
                                   Foreground="#EFE5F8"
                                   Text="Low-Level to Top — это платформа, где студенту понятно, что изучать, преподавателю удобно вести курсы, а администратору видно, как всё растёт."
                                   TextWrapping="Wrap" />

                        <WrapPanel Margin="0,14,0,0">
                            <Button Width="240"
                                    Margin="0,0,14,0"
                                    Style="{StaticResource LltLightButtonStyle}"
                                    Click="WhyItButton_OnClick"
                                    Content="Почему стоит попробовать IT?" />
                            <Button Width="170"
                                    Style="{StaticResource LltLightButtonStyle}"
                                    Click="FaqButton_OnClick"
                                    Content="FAQ по платформе" />
                        </WrapPanel>

                        <WrapPanel Margin="0,20,0,0">
                            <Button Width="210"
                                    Margin="0,0,14,0"
                                    Style="{StaticResource LltAccentButtonStyle}"
                                    Click="LoginButton_OnClick"
                                    Content="Войти в платформу" />
                            <Button Width="220"
                                    Style="{StaticResource LltLightButtonStyle}"
                                    Click="RegisterButton_OnClick"
                                    Content="Создать аккаунт" />
                        </WrapPanel>

                        <WrapPanel Margin="0,20,0,0">
                            <Border Margin="0,0,12,12"
                                    Padding="14,10"
                                    Background="#2A1238"
                                    BorderBrush="#5C3880"
                                    BorderThickness="1"
                                    CornerRadius="18">
                                <StackPanel>
                                    <TextBlock FontSize="24"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource LltLightTextBrush}"
                                               Text="{Binding CoursesCount}" />
                                    <TextBlock Foreground="#DCCCEC"
                                               Text="Курсов в каталоге" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,0,12,12"
                                    Padding="14,10"
                                    Background="#2A1238"
                                    BorderBrush="#5C3880"
                                    BorderThickness="1"
                                    CornerRadius="18">
                                <StackPanel>
                                    <TextBlock FontSize="24"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource LltLightTextBrush}"
                                               Text="{Binding CategoriesCount}" />
                                    <TextBlock Foreground="#DCCCEC"
                                               Text="Направлений" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,0,0,12"
                                    Padding="14,10"
                                    Background="#2A1238"
                                    BorderBrush="#5C3880"
                                    BorderThickness="1"
                                    CornerRadius="18">
                                <StackPanel>
                                    <TextBlock FontSize="24"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource LltLightTextBrush}"
                                               Text="3" />
                                    <TextBlock Foreground="#DCCCEC"
                                               Text="Роли в системе" />
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Padding="18"
                            Background="#190A20"
                            BorderBrush="#B596D1"
                            BorderThickness="1"
                            CornerRadius="24">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock HorizontalAlignment="Center"
                                       Foreground="#E6D6F7"
                                       FontSize="16"
                                       Text="LLT" />

                            <Border Grid.Row="1"
                                    Margin="0,14,0,14"
                                    CornerRadius="22"
                                    ClipToBounds="True">
                                <Image Source="/Assets/mascot.jpg"
                                       Stretch="UniformToFill" />
                            </Border>

                            <TextBlock Grid.Row="2"
                                       HorizontalAlignment="Center"
                                       Foreground="#E6D6F7"
                                       Text="Low-Level to Top" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,18,0,0"
                    Padding="22"
                    Background="#F2EDF7"
                    BorderBrush="#D7C8E7"
                    BorderThickness="1"
                    CornerRadius="24">
                <StackPanel>
                    <TextBlock FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource LltInkBrush}"
                               Text="Маршруты, которые уже доступны" />
                    <ItemsControl Margin="0,16,0,0"
                                  ItemsSource="{Binding Categories}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,12,12"
                                        Padding="14,8"
                                        Background="#6F4B96"
                                        BorderBrush="#B494D4"
                                        BorderThickness="1"
                                        CornerRadius="18">
                                    <TextBlock Foreground="{StaticResource LltLightTextBrush}"
                                               Text="{Binding}" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <TextBlock Grid.Row="2"
                       Margin="6,12,0,0"
                       Foreground="#9A1C30"
                       Text="{Binding ErrorMessage}"
                       TextWrapping="Wrap" />

            <Border Grid.Row="3"
                    Margin="0,18,0,0"
                    Padding="22"
                    Background="#F2EDF7"
                    BorderBrush="#D7C8E7"
                    BorderThickness="1"
                    CornerRadius="24">
                <StackPanel>
                    <TextBlock FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource LltInkBrush}"
                               Text="Что можно начать уже сейчас" />

                    <ItemsControl Margin="0,18,0,0"
                                  ItemsSource="{Binding FeaturedCourses}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="390"
                                        Margin="0,0,18,18"
                                        Padding="18"
                                        Background="#6F4B96"
                                        BorderBrush="#B494D4"
                                        BorderThickness="1"
                                        CornerRadius="22">
                                    <StackPanel>
                                        <TextBlock FontSize="22"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource LltLightTextBrush}"
                                                   Text="{Binding Title}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,10,0,0"
                                                   Foreground="#EEE5F8"
                                                   Text="{Binding Description}"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxHeight="66" />

                                        <WrapPanel Margin="0,14,0,0">
                                            <Border Margin="0,0,10,10"
                                                    Padding="10,4"
                                                    Background="#FCFAFE"
                                                    CornerRadius="16">
                                                <TextBlock Foreground="{StaticResource LltInkBrush}"
                                                           Text="{Binding CategoryName}" />
                                            </Border>
                                            <Border Margin="0,0,10,10"
                                                    Padding="10,4"
                                                    Background="#FCFAFE"
                                                    CornerRadius="16">
                                                <TextBlock Foreground="{StaticResource LltInkBrush}"
                                                           Text="{Binding Level}" />
                                            </Border>
                                            <Border Margin="0,0,0,10"
                                                    Padding="10,4"
                                                    Background="#63E62E"
                                                    CornerRadius="16">
                                                <TextBlock Foreground="{StaticResource LltAccentDarkBrush}"
                                                           Text="{Binding PriceCaption}" />
                                            </Border>
                                        </WrapPanel>

                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="#E7D8F7"
                                                   Text="{Binding MetaCaption}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Padding="24"
                            Background="#C5FFFFFF"
                            BorderBrush="#4EFFFFFF"
                            BorderThickness="1"
                            CornerRadius="24"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="18"
                                   Foreground="{StaticResource LltInkSoftBrush}"
                                   Text="Загружаем публичную витрину..."
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="4"
                    Margin="0,18,0,0"
                    Padding="24"
                    Background="#2A1238"
                    BorderBrush="#5C3880"
                    BorderThickness="1"
                    CornerRadius="24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource LltLightTextBrush}"
                                   Text="Хочешь увидеть весь путь внутри платформы?" />
                        <TextBlock Margin="0,10,0,0"
                                   Foreground="#DCCCEC"
                                   Text="Создай аккаунт, открой курс, проходи уроки, оставляй отзывы и следи за прогрессом в одном месте."
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <WrapPanel Grid.Column="1"
                               VerticalAlignment="Center">
                        <Button Width="190"
                                Margin="0,0,12,0"
                                Style="{StaticResource LltAccentButtonStyle}"
                                Click="RegisterButton_OnClick"
                                Content="Начать бесплатно" />
                        <Button Width="160"
                                Style="{StaticResource LltLightButtonStyle}"
                                Click="LoginButton_OnClick"
                                Content="Уже есть аккаунт" />
                    </WrapPanel>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
