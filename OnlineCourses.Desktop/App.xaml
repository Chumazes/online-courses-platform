<Application x:Class="OnlineCourses.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Color x:Key="LltShellColor">#1A0A20</Color>
        <Color x:Key="LltChromeColor">#25102F</Color>
        <Color x:Key="LltInkColor">#241230</Color>
        <Color x:Key="LltInkSoftColor">#5E4E69</Color>
        <Color x:Key="LltPanelColor">#6F4B96</Color>
        <Color x:Key="LltPanelStrongColor">#5E3D82</Color>
        <Color x:Key="LltPanelBorderColor">#B494D4</Color>
        <Color x:Key="LltInputColor">#FBF8FE</Color>
        <Color x:Key="LltLightBorderColor">#DCCDEB</Color>
        <Color x:Key="LltLightTextColor">#F8F3FD</Color>
        <Color x:Key="LltAccentColor">#63E62E</Color>
        <Color x:Key="LltAccentDarkColor">#355B20</Color>
        <Color x:Key="LltDangerColor">#EA4343</Color>

        <SolidColorBrush x:Key="LltShellBrush" Color="{StaticResource LltShellColor}" />
        <SolidColorBrush x:Key="LltChromeBrush" Color="{StaticResource LltChromeColor}" />
        <SolidColorBrush x:Key="LltInkBrush" Color="{StaticResource LltInkColor}" />
        <SolidColorBrush x:Key="LltInkSoftBrush" Color="{StaticResource LltInkSoftColor}" />
        <SolidColorBrush x:Key="LltPanelBrush" Color="{StaticResource LltPanelColor}" />
        <SolidColorBrush x:Key="LltPanelStrongBrush" Color="{StaticResource LltPanelStrongColor}" />
        <SolidColorBrush x:Key="LltPanelBorderBrush" Color="{StaticResource LltPanelBorderColor}" />
        <SolidColorBrush x:Key="LltInputBrush" Color="{StaticResource LltInputColor}" />
        <SolidColorBrush x:Key="LltLightBorderBrush" Color="{StaticResource LltLightBorderColor}" />
        <SolidColorBrush x:Key="LltLightTextBrush" Color="{StaticResource LltLightTextColor}" />
        <SolidColorBrush x:Key="LltAccentBrush" Color="{StaticResource LltAccentColor}" />
        <SolidColorBrush x:Key="LltAccentDarkBrush" Color="{StaticResource LltAccentDarkColor}" />
        <SolidColorBrush x:Key="LltDangerBrush" Color="{StaticResource LltDangerColor}" />

        <LinearGradientBrush x:Key="LltSceneBrush"
                             StartPoint="0,0"
                             EndPoint="0.95,1">
            <GradientStop Offset="0" Color="#CFC7D8" />
            <GradientStop Offset="0.34" Color="#F1EDF5" />
            <GradientStop Offset="0.7" Color="#9A94A3" />
            <GradientStop Offset="1" Color="#29242D" />
        </LinearGradientBrush>

        <RadialGradientBrush x:Key="LltGlowBrush"
                             Center="0.5,0.46"
                             GradientOrigin="0.5,0.46"
                             RadiusX="0.68"
                             RadiusY="0.52">
            <GradientStop Offset="0" Color="#70FFFFFF" />
            <GradientStop Offset="0.45" Color="#18FFFFFF" />
            <GradientStop Offset="1" Color="#00FFFFFF" />
        </RadialGradientBrush>

        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="Foreground" Value="{StaticResource LltInkBrush}" />
        </Style>

        <Style TargetType="Page">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource LltInkBrush}" />
            <Setter Property="TextElement.FontFamily" Value="Bahnschrift" />
        </Style>

        <Style x:Key="LltHeaderButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Foreground" Value="{StaticResource LltLightTextBrush}" />
            <Setter Property="Background" Value="#311142" />
            <Setter Property="BorderBrush" Value="#7A53A4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#45205D" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#572978" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LltPrimaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource LltHeaderButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource LltLightTextBrush}" />
            <Setter Property="Background" Value="{StaticResource LltPanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LltPanelBorderBrush}" />
        </Style>

        <Style x:Key="LltAccentButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource LltHeaderButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource LltAccentDarkBrush}" />
            <Setter Property="Background" Value="{StaticResource LltAccentBrush}" />
            <Setter Property="BorderBrush" Value="#8FF268" />
        </Style>

        <Style x:Key="LltLightButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource LltHeaderButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource LltInkBrush}" />
            <Setter Property="Background" Value="#F5EFFB" />
            <Setter Property="BorderBrush" Value="#E1D3EE" />
        </Style>

        <Style x:Key="LltDangerButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource LltHeaderButtonStyle}">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource LltDangerBrush}" />
            <Setter Property="BorderBrush" Value="#F48A8A" />
        </Style>

        <Style x:Key="LltLinkButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#F5EEFE" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="LltTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource LltInputBrush}" />
            <Setter Property="Foreground" Value="{StaticResource LltInkBrush}" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="BorderBrush" Value="#D5C3E7" />
            <Setter Property="Padding" Value="18,12" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#8D69B6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LltPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Background" Value="{StaticResource LltInputBrush}" />
            <Setter Property="Foreground" Value="{StaticResource LltInkBrush}" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="BorderBrush" Value="#D5C3E7" />
            <Setter Property="Padding" Value="18,12" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#8D69B6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LltComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Background" Value="{StaticResource LltInputBrush}" />
            <Setter Property="Foreground" Value="{StaticResource LltInkBrush}" />
            <Setter Property="BorderBrush" Value="#DCCDEB" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Foreground" Value="{StaticResource LltAccentBrush}" />
            <Setter Property="Background" Value="#D6C6E6" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource LltInkBrush}" />
            <Setter Property="FontSize" Value="15" />
        </Style>
    </Application.Resources>
</Application>
